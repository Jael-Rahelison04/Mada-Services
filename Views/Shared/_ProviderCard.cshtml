@* Views/Shared/_ProviderCard.cshtml
   Partial View réutilisable — Carte d'un prestataire
   Utilisée par : Home/Index.cshtml et Provider/Index.cshtml *@

@model MadaServices.Models.Provider

@{
    var avg = (Model.Reviews != null && Model.Reviews.Any())
        ? Model.Reviews.Average(r => r.Rating)
        : 0;
}

<style>
    :root {
        --indigo-main: #6c5ce7;
        --indigo-dark: #5649c1;
        --indigo-soft: #f0eeff;
        --emerald:     #00b894;
    }

    .provider-card {
        border: 1px solid #f0f0f0;
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        background: white;
        overflow: hidden;
    }
    .provider-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(108, 92, 231, 0.12) !important;
        border-color: var(--indigo-main);
    }

    /* Avatar */
    .avatar-container {
        position: relative;
        width: 65px; height: 65px;
        flex-shrink: 0;
    }
    .avatar-circle {
        width: 100%; height: 100%;
        background: linear-gradient(135deg, var(--indigo-main), #a29bfe);
        color: white;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; font-weight: 800;
        border-radius: 20px;
    }

    /* Point de statut (dispo / en pause) */
    .status-dot {
        position: absolute;
        bottom: -2px; right: -2px;
        width: 16px; height: 16px;
        border: 3px solid white;
        border-radius: 50%;
    }
    .status-online  { background: var(--emerald); }
    .status-offline { background: #94a3b8; }

    /* Badge vérifié */
    .badge-verified {
        background: var(--indigo-soft);
        color: var(--indigo-main);
        font-size: 0.7rem; font-weight: 700;
        padding: 4px 12px;
        border-radius: 50px;
        letter-spacing: 0.5px;
    }

    .text-indigo { color: var(--indigo-main); }

    /* Miniatures portfolio */
    .portfolio-img-wrapper {
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #f0f0f0;
    }
    .portfolio-img-wrapper img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }
    .portfolio-img-wrapper:hover img { transform: scale(1.1); }

    /* Bouton */
    .btn-view {
        background: var(--indigo-main);
        color: white; border-radius: 16px;
        font-weight: 700; border: none;
        transition: 0.3s;
    }
    .btn-view:hover {
        background: var(--indigo-dark); color: white;
        box-shadow: 0 8px 15px rgba(108, 92, 231, 0.3);
    }

    /* Prix */
    .price-tag { font-size: 1.3rem; font-weight: 800; color: #2d3436; }
</style>

<div class="card provider-card h-100 p-3">
    <div class="card-body d-flex flex-column">


        <div class="d-flex align-items-center mb-3">
            <div class="avatar-container me-3">
                @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
                    <img src="@Model.ImageUrl"
                         class="avatar-circle"
                         style="object-fit: cover;"
                         alt="@Model.FullName">
                } else {
                    <div class="avatar-circle">
                        <span>@(Model.FullName?.Substring(0, 1).ToUpper() ?? "P")</span>
                    </div>
                }
                <div class="status-dot @(Model.IsPaused ? "status-offline" : "status-online")"></div>
            </div>

            <div class="overflow-hidden">
                <h5 class="fw-800 mb-0 text-truncate">@(Model.FullName ?? "Prestataire")</h5>
                <div class="d-flex align-items-center gap-2 mt-1">
                    <small class="text-muted">
                        <i class="bi bi-geo-alt"></i> @Model.City
                    </small>
                    @if (Model.IsVerified) {
                        <span class="badge-verified">
                            <i class="bi bi-patch-check-fill me-1"></i>Vérifié
                        </span>
                    }
                </div>
            </div>
        </div>


        <h6 class="text-indigo fw-800 mb-2">@Model.JobTitle</h6>
        <p class="text-muted small mb-4">
            @(Model.Description?.Length > 95
                ? Model.Description.Substring(0, 95) + "..."
                : Model.Description)
        </p>


        @if (Model.PortfolioItems != null && Model.PortfolioItems.Any()) {
            <div class="row g-2 mb-4">
                @foreach (var item in Model.PortfolioItems.Take(3)) {
                    <div class="col-4">
                        <div class="portfolio-img-wrapper">
                            <img src="@item.ImageUrl" alt="Réalisation">
                        </div>
                    </div>
                }
            </div>
        }


        <div class="mt-auto">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div>
                    <div class="text-warning small mb-1">
                        @for (int i = 1; i <= 5; i++) {
                            <i class="bi @(i <= Math.Round(avg) ? "bi-star-fill" : "bi-star text-muted opacity-25")"></i>
                        }
                    </div>
                    <span class="text-muted" style="font-size: 0.75rem;">
                        (@(Model.Reviews?.Count ?? 0) avis)
                    </span>
                </div>
                <div class="text-end">
                    <div class="price-tag">
                        @if (Model.HourlyRate > 0) {
                            @Model.HourlyRate.ToString("N0")
                            <small style="font-size: 0.7rem; font-weight: 600;">Ar/h</small>
                        } else {
                            <span>Sur devis</span>
                        }
                    </div>
                </div>
            </div>

            <a asp-controller="Provider"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn btn-view w-100 py-3">
                Consulter le Profil
            </a>
        </div>

    </div>
</div>