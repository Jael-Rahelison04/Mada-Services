<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MadaServices</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        :root {
            --brand-dark: #0f172a; 
            --brand-main: #4338ca; 
            --brand-accent: #10b981; 
            --brand-admin: #312e81; 
            --brand-bg: #f8fafc;
            --primary-gradient: linear-gradient(135deg, #4338ca 0%, #1e1b4b 100%);
            --admin-gradient: linear-gradient(135deg, #312e81 0%, #0f172a 100%);
            --glass-bg: rgba(255, 255, 255, 0.9);
        }

        /* --- Correction de la structure Sticky Footer --- */
        html, body { height: 100%; }

        body { 
            font-family: 'Outfit', sans-serif; 
            background: var(--brand-bg); 
            color: #334155;
            display: flex;
            flex-direction: column;
            padding-top: 80px; /* Espace pour la navbar fixe */
        }

        /* --- Navbar Restylisée (Glassmorphism) --- */
        .navbar-custom { 
            background: var(--glass-bg); 
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            z-index: 1050;
            position: fixed;
            top: 0;
            width: 100%;
            transition: all 0.3s ease;
        }

        .navbar-brand { font-weight: 800; letter-spacing: -0.8px; font-size: 1.5rem; }

        .nav-link {
            font-weight: 600;
            color: #475569 !important;
            padding: 0.5rem 1rem;
            transition: 0.2s;
        }
        .nav-link:hover { color: var(--brand-main) !important; }

        /* --- User Badge & Profil --- */
        .user-badge {
            background: rgba(241, 245, 249, 0.8);
            padding: 6px 14px;
            border-radius: 14px;
            border: 1px solid var(--border-color);
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .user-badge:hover { background: white; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); border-color: var(--brand-main); }

        /* --- Main Content Area --- */
        main { flex: 1 0 auto; }

        /* --- Boutons --- */
        .btn-vibrant { 
            background: var(--brand-accent); 
            color: white !important; 
            border: none; 
            border-radius: 12px;
            padding: 0.7rem 1.6rem;
            font-weight: 700;
            box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3);
            transition: all 0.3s;
        }
        .btn-vibrant:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4); }

        /* --- Footer Moderne --- */
        .footer-modern { 
            background: var(--brand-dark); 
            color: #f8fafc; 
            padding: 60px 0 30px;
            border-radius: 40px 40px 0 0;
            margin-top: auto;
        }

        .footer-link { color: #94a3b8; text-decoration: none; transition: 0.3s; font-size: 0.95rem; }
        .footer-link:hover { color: var(--brand-accent); padding-left: 5px; }

        .social-icon {
            width: 40px; height: 40px;
            background: rgba(255,255,255,0.08);
            border-radius: 12px;
            display: inline-flex; align-items: center; justify-content: center;
            color: white; transition: 0.3s;
        }
        .social-icon:hover { background: var(--brand-main); transform: rotate(10deg); }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <div class="rounded-3 me-2 d-flex align-items-center justify-content-center shadow-sm" 
                         style="width: 38px; height: 38px; background: var(--primary-gradient);">
                        <i class="bi bi-intersect text-white fs-4"></i>
                    </div>
                    <span><span style="color: var(--brand-dark)">Mada</span><span style="color: var(--brand-main)">Services</span></span>
                </a>
                
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                    <i class="bi bi-grid-fill fs-2 text-primary"></i>
                </button>
                
                <div class="collapse navbar-collapse" id="navContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-5">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Provider" asp-action="Index">
                                <i class="bi bi-search me-1"></i> Trouver un expert
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var userName = User.Identity.Name ?? "Utilisateur";
                            var isAdmin = User.IsInRole("Admin");
                            var isProvider = User.IsInRole("Provider");

                            <li class="nav-item dropdown">
                                <a class="nav-link user-badge d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <div class="rounded-circle me-2 d-flex align-items-center justify-content-center shadow-sm position-relative" 
                                         style="width: 34px; height: 34px; background: @(isAdmin ? "var(--admin-gradient)" : "var(--primary-gradient)"); color: white;">
                                        @if(isAdmin) { <i class="bi bi-shield-check" style="font-size: 1rem;"></i> }
                                        else { <span class="small fw-bold">@userName.Substring(0, 1).ToUpper()</span> }
                                        <span class="position-absolute bottom-0 end-0 p-1 border border-2 border-white rounded-circle @(isAdmin ? "bg-dark" : (isProvider ? "bg-primary" : "bg-success"))" style="width: 11px; height: 11px;"></span>
                                    </div>
                                    
                                    <div class="d-none d-md-flex flex-column align-items-start me-2">
                                        <span class="small fw-800 text-brand-dark lh-1">@userName.Split('@')[0]</span>
                                        <span style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; color: var(--brand-main)">
                                            @(isAdmin ? "Admin" : (isProvider ? "Prestataire" : "Client"))
                                        </span>
                                    </div>
                                    <i class="bi bi-chevron-down small opacity-50"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3 p-2 rounded-4">
                                    @if (isAdmin) {
                                        <li><a class="dropdown-item rounded-3 py-2 fw-bold text-indigo" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Administration</a></li>
                                    }
                                    else if (isProvider) {
                                        <li><a class="dropdown-item rounded-3 py-2" asp-controller="Provider" asp-action="Dashboard"><i class="bi bi-grid-1x2 me-2 text-primary"></i>Mon Dashboard</a></li>
                                    } else {
                                        <li><a class="dropdown-item rounded-3 py-2" asp-controller="Customer" asp-action="Index"><i class="bi bi-person-circle me-2 text-success"></i>Mon Espace</a></li>
                                    }
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger rounded-3 py-2 w-100 border-0 bg-transparent text-start">
                                                <i class="bi bi-box-arrow-right me-2"></i> Déconnexion
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link px-3" asp-controller="Account" asp-action="Login">Connexion</a></li>
                            <li class="nav-item"><a class="btn btn-vibrant px-4" asp-controller="Account" asp-action="Register">Rejoindre</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="footer-modern">
        <div class="container">
            <div class="row g-4 mb-5">
                <div class="col-lg-5">
                    <h5 class="text-white fw-800 mb-3">MadaServices</h5>
                    <p class="small text-white-50 pe-lg-5">
                        Simplifier l'accès aux services professionnels à Madagascar. Connecter les talents locaux avec ceux qui en ont besoin, en toute sécurité.
                    </p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-3">
                    <h6 class="text-white fw-700 mb-4 text-uppercase small">Navigation</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="footer-link">Accueil</a></li>
                        <li class="mb-2"><a asp-controller="Provider" asp-action="Index" class="footer-link">Trouver un expert</a></li>
                        <li class="mb-2"><a asp-controller="Account" asp-action="Register" class="footer-link">Devenir Prestataire</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-4">
                    <h6 class="text-white fw-700 mb-4 text-uppercase small">Contact & Support</h6>
                    <p class="small text-white-50 mb-2"><i class="bi bi-envelope-fill me-2 text-accent"></i> support@madaservices.mg</p>
                    <p class="small text-white-50"><i class="bi bi-geo-alt-fill me-2 text-accent"></i> Antananarivo, Madagascar</p>
                </div>
            </div>
            <div class="pt-4 border-top border-secondary border-opacity-25 text-center">
                <p class="small mb-0 opacity-50">&copy; 2026 MadaServices • Conçu avec passion à Madagascar</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>