@* Views/Shared/_StarRating.cshtml
   Usage : @await Html.PartialAsync("_StarRating", (decimal)review.Rating)
   Affiche des étoiles pleines, demi ou vides selon la note décimale *@

@model decimal

@{
    decimal rating = Model;
}

<span class="star-display text-warning" title="@rating / 5">
    @for (int i = 1; i <= 5; i++) {
        if (rating >= i) {
            <i class="bi bi-star-fill"></i>
        } else if (rating >= i - 0.5m) {
            <i class="bi bi-star-half"></i>
        } else {
            <i class="bi bi-star text-muted opacity-25"></i>
        }
    }
</span>