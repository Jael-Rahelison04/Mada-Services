@model MadaServices.Models.Provider
@{
    ViewData["Title"] = "Tableau de Bord Pro - MadaServices";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container py-5">
    @* --- EN-TÊTE DU PROFIL (Modifié avec Contact & Avis) --- *@
    <header class="row align-items-center mb-5 gy-3">
        <div class="col-md-8">
            <div class="d-flex align-items-center">
                <div class="position-relative avatar-container" title="Changer la photo de profil">
                    <form asp-controller="Provider" asp-action="UploadAvatar" method="post" enctype="multipart/form-data" id="avatarForm">
                        @Html.AntiForgeryToken()
                        <input type="file" name="avatarFile" id="avatarInput" class="d-none" onchange="document.getElementById('avatarForm').submit()">
                        <label for="avatarInput" class="mb-0 cursor-pointer">
                            <div class="rounded-circle border border-4 border-white shadow-sm overflow-hidden position-relative avatar-wrapper">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
                                    <img src="@Model.ImageUrl" class="w-100 h-100" style="object-fit: cover;">
                                } else {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-gradient-pro text-white">
                                        <span class="fs-2 fw-bold">@Model.FullName?[0]</span>
                                    </div>
                                }
                                <div class="avatar-overlay">
                                    <i class="bi bi-camera-fill text-white fs-5"></i>
                                </div>
                            </div>
                        </label>
                    </form>
                    @if(Model.IsVerified) {
                        <span class="position-absolute bottom-0 end-0 bg-success border border-2 border-white rounded-circle p-1 shadow">
                            <i class="bi bi-patch-check-fill text-white" style="font-size: 0.8rem;"></i>
                        </span>
                    }
                </div>

                <div class="ms-4">
                    <h2 class="fw-800 text-dark mb-1">@Model.FullName</h2>
                    
                    @* INFOS DE CONTACT *@
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2 small text-muted">
                        <span title="Email professionnel"><i class="bi bi-envelope-at me-1 text-primary"></i>@Model.Email</span>
                        @if(!string.IsNullOrEmpty(Model.PhoneNumber)) {
                            <span title="Téléphone"><i class="bi bi-telephone me-1 text-primary"></i>@Model.PhoneNumber</span>
                        }
                    </div>

                    <div class="d-flex align-items-center flex-wrap gap-2">
                        <span class="badge rounded-pill px-3 bg-white text-dark border">@(Model.JobTitle ?? "Prestataire")</span>
                        
                        @* NOMBRE D'AVIS & NOTE *@
                        <div class="d-flex align-items-center bg-white rounded-pill px-2 border py-1 shadow-xs">
                            <i class="bi bi-star-fill text-warning me-1 small"></i>
                            <span class="fw-bold text-dark small">@Model.AverageRating.ToString("F1")</span>
                            <span class="text-muted small ms-1">(@(Model.Reviews?.Count ?? 0) avis)</span>
                        </div>

                        @if(Model.IsPaused) {
                            <span class="badge bg-warning text-dark rounded-pill shadow-sm animate-pulse">
                                <i class="bi bi-eye-slash-fill me-1"></i>En pause
                            </span>
                        } else {
                            <span class="badge bg-success text-white rounded-pill shadow-sm">
                                <i class="bi bi-eye-fill me-1"></i>Profil Public
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 text-md-end">
            <form asp-controller="Provider" asp-action="TogglePause" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn @(Model.IsPaused ? "btn-success" : "btn-outline-warning") rounded-pill px-4 fw-600 shadow-sm transition-all">
                    <i class="bi @(Model.IsPaused ? "bi-play-circle-fill" : "bi-pause-circle-fill") me-1"></i>
                    @(Model.IsPaused ? "Réactiver mon profil" : "Mettre en pause")
                </button>
            </form>
        </div>
    </header>

    <div class="row g-4">
        @* --- NAVIGATION LATÉRALE --- *@
        <div class="col-lg-3">
            <div class="nav flex-column nav-pills sidebar-nav shadow-sm p-3 bg-white rounded-4 border sticky-top" style="top: 20px;" id="v-pills-tab" role="tablist">
                <button class="nav-link active mb-2" data-bs-toggle="pill" data-bs-target="#profile">
                    <i class="bi bi-person-gear me-2"></i>Mon Profil
                </button>
                <button class="nav-link mb-2 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#missions">
                    <span><i class="bi bi-briefcase me-2"></i>Mes Missions</span>
                    <span class="badge rounded-pill bg-danger">@(Model.Bookings?.Count(b => b.Status == "Pending") ?? 0)</span>
                </button>
                <button class="nav-link mb-2" data-bs-toggle="pill" data-bs-target="#calendar">
                    <i class="bi bi-calendar3 me-2"></i>Disponibilités
                </button>
                <button class="nav-link mb-2" data-bs-toggle="pill" data-bs-target="#wallet">
                    <i class="bi bi-wallet2 me-2"></i>Portefeuille
                </button>
                <hr class="my-2 opacity-10">
                <button class="nav-link mb-2 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#portfolio">
                    <span><i class="bi bi-grid-1x2 me-2"></i>Portfolio</span>
                    <span class="badge rounded-pill bg-light text-dark border">@(Model.PortfolioItems?.Count ?? 0)</span>
                </button>
                <button class="nav-link mb-2" data-bs-toggle="pill" data-bs-target="#reputation">
                    <i class="bi bi-star me-2"></i>Avis (@(Model.Reviews?.Count ?? 0))
                </button>
                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#verification">
                    <i class="bi bi-shield-check me-2"></i>Vérification
                </button>
            </div>
        </div>

        @* --- CONTENU PRINCIPAL --- *@
        <div class="col-lg-9">
            <div class="tab-content bg-white rounded-4 shadow-sm p-4 p-md-5 border min-vh-75">
                
                @* 1. SECTION : PROFIL *@
                <div class="tab-pane fade show active" id="profile">
                    <h4 class="fw-800 mb-4">Informations Publiques</h4>
                    <form asp-controller="Provider" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-4">

                            <div class="col-md-6">
                                <label class="label-pro">MÉTIER / TITRE</label>
                                <input name="JobTitle"
                                    value="@Model.JobTitle"
                                    class="form-control input-pro"
                                    required>
                            </div>

                            <div class="col-md-6">
                                <label class="label-pro">VILLE</label>
                                <input name="City"
                                    value="@Model.City"
                                    class="form-control input-pro"
                                    required>
                            </div>

                            <div class="col-md-6">
                                <label class="label-pro">TARIF HORAIRE (Ar)</label>
                                <input type="text"
                                    name="HourlyRate"
                                    value="@Model.HourlyRate.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)"
                                    class="form-control input-pro"
                                    placeholder="Ex: 15000"
                                    pattern="[0-9]+"
                                    inputmode="numeric">
                                <div class="form-text text-muted">Entrez un montant entier en Ariary</div>
                            </div>

                            <div class="col-md-6">
                                <label class="label-pro">TÉLÉPHONE DE CONTACT</label>
                                <input type="tel"
                                    name="PhoneNumber"
                                    value="@(Model.Phone ?? Model.PhoneNumber ?? "")"
                                    class="form-control input-pro"
                                    placeholder="+261 34 XX XXX XX">
                            </div>

                            <div class="col-md-12">
                                <label class="label-pro">CATÉGORIE DE SERVICE</label>

                                @{
                                    // Récupérer la liste depuis le ViewBag
                                    var categoriesList = ViewBag.Categories as
                                        List<MadaServices.Models.Category>
                                        ?? new List<MadaServices.Models.Category>();
                                }

                                @if (categoriesList.Any())
                                {
                                    <select name="CategoryId" class="form-select input-pro">

                                        <option value="0" selected="@(Model.CategoryId == null || Model.CategoryId == 0)">
                                            — Choisir une catégorie —
                                        </option>

                                        <!-- Pour la boucle foreach -->
                                        @foreach (var cat in categoriesList)
                                        {
                                            <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">
                                                @cat.Name
                                            </option>
                                        }
                                    </select>

                                    @if (Model.Category != null)
                                    {
                                        <div class="mt-2 d-flex align-items-center gap-2">
                                            <span class="text-muted small">Catégorie actuelle :</span>
                                            <span class="badge rounded-pill px-3 py-2"
                                                style="background:#ecfdf5; color:#059669; font-weight:700;">
                                                <i class="bi bi-tag-fill me-1"></i>@Model.Category.Name
                                            </span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="alert alert-light border rounded-3 py-2 px-3 small">
                                        <i class="bi bi-info-circle text-muted me-2"></i>
                                        Aucune catégorie disponible. Demandez à l'administrateur d'en créer.
                                    </div>
                                }
                            </div>

                            <div class="col-md-12">
                                <label class="label-pro">DESCRIPTION</label>
                                <textarea name="Description"
                                        class="form-control input-pro"
                                        rows="4">@Model.Description</textarea>
                            </div>

                            <div class="col-12 text-end mt-4">
                                <button type="submit" class="btn btn-primary-mada px-5 rounded-pill shadow-sm">
                                    <i class="bi bi-save me-2"></i>Mettre à jour mon profil
                                </button>
                            </div>

                        </div>
                    </form>
                </div>

                @* 2. SECTION : MISSIONS *@
                <div class="tab-pane fade" id="missions">
                    <h4 class="fw-800 mb-4">Suivi des Missions</h4>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Client / Service</th>
                                    <th>Prix</th>
                                    <th>Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Bookings?.Any() == true) {
                                    @foreach (var booking in Model.Bookings.OrderByDescending(b => b.CreatedAt)) {
                                        <tr>
                                            <td>
                                                <strong>@booking.CustomerName</strong><br>
                                                <small class="text-muted">@booking.ServiceName</small>
                                            </td>
                                            <td>@booking.TotalPrice.ToString("N0") Ar</td>
                                            <td>
                                                @if(booking.Status == "Pending") { <span class="badge bg-warning-soft text-warning rounded-pill">En attente</span> }
                                                else if(booking.Status == "Completed") { <span class="badge bg-success-soft text-success rounded-pill">Terminé</span> }
                                                else { <span class="badge bg-primary-soft text-primary rounded-pill">@booking.Status</span> }
                                            </td>
                                            <td class="text-end">
                                                @if(booking.Status == "Pending") {
                                                    <form asp-action="UpdateBookingStatus" method="post" class="d-inline">
                                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                                        <input type="hidden" name="status" value="Accepted" />
                                                        <button type="submit" class="btn btn-sm btn-success rounded-pill">Accepter</button>
                                                    </form>
                                                }
                                                @if(booking.Status == "Accepted") {
                                                    <form asp-action="UpdateBookingStatus" method="post" class="d-inline">
                                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                                        <input type="hidden" name="status" value="Completed" />
                                                        <button type="submit" class="btn btn-sm btn-outline-primary rounded-pill">Terminer</button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                } else {
                                    <tr><td colspan="4" class="text-center py-4 text-muted">Aucune mission pour le moment.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* 3. SECTION : CALENDRIER *@
                <div class="tab-pane fade" id="calendar">
                    <h4 class="fw-800 mb-4">Disponibilités Hebdomadaires</h4>
                    <div class="p-4 bg-light rounded-4">
                        <div class="row g-3">
                            @foreach (var jour in new[] { "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi", "Samedi", "Dimanche" }) {
                                var isAvailable = Model.Availabilities?.Any(a => a.DayOfWeek == jour && a.IsActive) ?? false;
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-between align-items-center p-3 bg-white rounded-3 border shadow-sm">
                                        <span class="fw-600">@jour</span>
                                        <div class="form-check form-switch">
                                            <input class="form-check-input availability-toggle" type="checkbox" 
                                                   data-day="@jour" @(isAvailable ? "checked" : "")>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* 4. SECTION : PORTEFEUILLE *@
                <div class="tab-pane fade" id="wallet">
                    <h4 class="fw-800 mb-4">Mon Portefeuille</h4>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="bg-gradient-pro text-white p-4 rounded-4 shadow-lg h-100">
                                <small class="opacity-75">Solde Actuel (Terminé)</small>
                                <h2 class="fw-800 mb-0">@((Model.Bookings?.Where(b => b.Status == "Completed").Sum(b => b.TotalPrice) ?? 0).ToString("N0")) Ar</h2>
                                <button class="btn btn-light btn-sm rounded-pill mt-3 px-3 fw-bold">Retirer fonds</button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border p-4 rounded-4 h-100 bg-light">
                                <small class="text-muted">Missions en cours</small>
                                <h3 class="fw-bold text-primary mb-0">@((Model.Bookings?.Where(b => b.Status != "Completed").Sum(b => b.TotalPrice) ?? 0).ToString("N0")) Ar</h3>
                                <small class="text-muted">@(Model.Bookings?.Count(b => b.Status != "Completed") ?? 0) dossiers actifs</small>
                            </div>
                        </div>
                    </div>
                </div>

                @* 5. SECTION : PORTFOLIO *@
                <!-- ✅ CORRECTION P12 : Afficher le compteur et bloquer si limite atteinte -->
                <div class="tab-pane fade" id="portfolio">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-800">Ma Galerie Portfolio</h4>
                        <!-- Compteur de photos -->
                        <span class="badge @(Model.PortfolioCount >= 10 ? "bg-danger" : "bg-primary") rounded-pill px-3 py-2">
                            @Model.PortfolioCount / 10 photos
                        </span>
                    </div>

                    <!-- Formulaire d'upload : visible seulement si moins de 10 photos -->
                    @if (Model.PortfolioCount < 10)
                    {
                        <form asp-controller="Provider" asp-action="UploadPortfolio"
                            method="post" enctype="multipart/form-data"
                            class="mb-5 p-4 bg-light rounded-4 border">
                            @Html.AntiForgeryToken()
                            <div class="row g-3">
                                <div class="col-md-5">
                                    <label class="label-pro">NOUVELLE IMAGE</label>
                                    <input type="file" name="portfolioFile" class="form-control" required
                                        accept=".jpg,.jpeg,.png,.webp,.gif">
                                </div>
                                <div class="col-md-5">
                                    <label class="label-pro">LÉGENDE</label>
                                    <input type="text" name="description" class="form-control"
                                        placeholder="Titre du projet">
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2">
                                        Ajouter
                                    </button>
                                </div>
                            </div>
                            <p class="text-muted small mt-2 mb-0">
                                <i class="bi bi-info-circle me-1"></i>
                                Il vous reste <strong>@(10 - Model.PortfolioCount)</strong> emplacement(s).
                            </p>
                        </form>
                    }
                    else
                    {
                        <!-- Message quand la limite est atteinte -->
                        <div class="alert alert-warning rounded-4 mb-4 d-flex align-items-center gap-3">
                            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                            <div>
                                <strong>Limite atteinte !</strong> Vous avez 10 photos dans votre portfolio.
                                Supprimez une photo pour en ajouter une nouvelle.
                            </div>
                        </div>
                    }

                    <!-- Galerie -->
                    <div class="row g-3">
                        @if (Model.PortfolioItems?.Any() == true) {
                            @foreach (var item in Model.PortfolioItems) {
                                <div class="col-md-4">
                                    <div class="portfolio-card shadow-sm border bg-white rounded-3 overflow-hidden">
                                        <img src="@item.ImageUrl" class="w-100" style="height:180px; object-fit:cover;">
                                        <div class="p-2 d-flex justify-content-between align-items-center">
                                            <span class="small fw-bold text-truncate me-2">@item.Description</span>
                                            <!-- ✅ CORRECTION P8 : Formulaire pointe vers Provider (pas Dashboard) -->
                                            <form asp-controller="Provider" asp-action="DeletePortfolioItem" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-link text-danger p-0"
                                                        onclick="return confirm('Supprimer cette photo ?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        } else {
                            <div class="col-12 text-center py-4 text-muted">
                                <i class="bi bi-images display-4 d-block mb-2 opacity-25"></i>
                                Aucune réalisation ajoutée pour le moment.
                            </div>
                        }
                    </div>
                </div>

                @* 6. SECTION : AVIS CLIENTS *@
                <div class="tab-pane fade" id="reputation">
                    <h4 class="fw-800 mb-4">Avis Clients (@(Model.Reviews?.Count ?? 0))</h4>
                    @if (Model.Reviews?.Any() == true) {
                        @foreach(var review in Model.Reviews.OrderByDescending(r => r.DatePosted)) {
                            <div class="card border-0 bg-light rounded-4 p-4 mb-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <div>
                                        <span class="fw-bold">@review.CustomerName</span>
                                        <small class="text-muted ms-2">@review.DatePosted.ToShortDateString()</small>
                                    </div>
                                    <span class="text-warning">
                                        @for(int i=0; i<5; i++) { <i class="bi @(i < review.Rating ? "bi-star-fill" : "bi-star")"></i> }
                                    </span>
                                </div>
                                <p class="mb-0 text-muted">"@review.Comment"</p>
                            </div>
                        }
                    } else {
                        <div class="text-center py-5">
                            <i class="bi bi-chat-left-quote display-1 text-light"></i>
                            <p class="text-muted mt-3">Vous n'avez pas encore reçu d'avis.</p>
                        </div>
                    }
                </div>

                @* 7. SECTION : VÉRIFICATION *@
                <!-- ✅ CORRECTION P10 : Section vérification complète et fonctionnelle -->
                <div class="tab-pane fade" id="verification">
                    <h4 class="fw-800 mb-4">Vérification d'Identité</h4>

                    @if (Model.IsVerified)
                    {
                        <!-- Cas 1 : Déjà vérifié -->
                        <div class="alert alert-success rounded-4 d-flex align-items-center p-4">
                            <i class="bi bi-patch-check-fill fs-1 me-4 text-success"></i>
                            <div>
                                <h5 class="fw-bold mb-1">✅ Profil Certifié</h5>
                                <p class="mb-0 small">
                                    Votre identité a été vérifiée. Vous bénéficiez d'une meilleure
                                    visibilité et d'un badge de confiance sur votre profil.
                                </p>
                            </div>
                        </div>
                    }
                    else if (Model.VerificationStatus == "Pending")
                    {
                        <!-- Cas 2 : Document envoyé, en attente de validation -->
                        <div class="alert alert-info rounded-4 d-flex align-items-center p-4">
                            <i class="bi bi-hourglass-split fs-1 me-4 text-primary"></i>
                            <div>
                                <h5 class="fw-bold mb-1">⏳ Dossier en cours d'examen</h5>
                                <p class="mb-0 small">
                                    Vos documents ont bien été reçus. L'administrateur validera
                                    votre profil dans un délai de 48h ouvrées.
                                </p>
                            </div>
                        </div>
                    }
                    else if (Model.VerificationStatus == "Rejected")
                    {
                        <!-- Cas 3 : Document rejeté → permettre de re-soumettre -->
                        <div class="alert alert-danger rounded-4 mb-4 d-flex align-items-center p-4">
                            <i class="bi bi-x-circle-fill fs-1 me-4 text-danger"></i>
                            <div>
                                <h5 class="fw-bold mb-1">❌ Dossier refusé</h5>
                                <p class="mb-0 small">
                                    Votre document n'a pas pu être accepté. Veuillez soumettre
                                    un document plus lisible ou un document valide.
                                </p>
                            </div>
                        </div>

                        <!-- Formulaire de re-soumission -->
                        <form asp-controller="Provider" asp-action="UploadVerificationDocument"
                            method="post" enctype="multipart/form-data"
                            class="p-4 bg-light rounded-4 border">
                            @Html.AntiForgeryToken()
                            <label class="label-pro mb-2">NOUVEAU DOCUMENT (CIN, Passeport ou Diplôme)</label>
                            <div class="input-group">
                                <input type="file" name="documentFile" class="form-control"
                                    accept=".jpg,.jpeg,.png,.pdf" required>
                                <button type="submit" class="btn btn-danger px-4 fw-bold">
                                    Re-soumettre
                                </button>
                            </div>
                            <p class="text-muted small mt-2 mb-0">Formats acceptés : jpg, png, pdf — max 5 Mo</p>
                        </form>
                    }
                    else
                    {
                        <!-- Cas 4 : Jamais soumis (NotSubmitted) -->
                        <div class="card border-0 bg-light rounded-4 p-5 text-center mb-4">
                            <i class="bi bi-shield-lock display-4 text-muted mb-3"></i>
                            <h5 class="fw-bold mb-2">Obtenez le badge de confiance</h5>
                            <p class="text-muted small mx-auto mb-0" style="max-width: 450px;">
                                Téléversez une pièce d'identité (CIN ou Passeport) pour certifier
                                votre profil. Cela augmente votre visibilité et inspire confiance aux clients.
                            </p>
                        </div>

                        <!-- ✅ CORRECTION P10 : Formulaire fonctionnel avec action correcte -->
                        <form asp-controller="Provider" asp-action="UploadVerificationDocument"
                            method="post" enctype="multipart/form-data"
                            class="p-4 bg-white rounded-4 border shadow-sm">
                            @Html.AntiForgeryToken()
                            <div class="row g-3 align-items-end">
                                <div class="col-md-8">
                                    <label class="label-pro mb-2">
                                        DOCUMENT D'IDENTITÉ (CIN, Passeport ou Diplôme)
                                    </label>
                                    <input type="file" name="documentFile" class="form-control"
                                        accept=".jpg,.jpeg,.png,.pdf" required>
                                    <p class="text-muted small mt-1 mb-0">
                                        Formats acceptés : jpg, png, pdf — max 5 Mo
                                    </p>
                                </div>
                                <div class="col-md-4">
                                    <button type="submit" class="btn btn-primary-mada w-100 rounded-pill py-3 fw-bold">
                                        <i class="bi bi-cloud-upload me-2"></i>Envoyer le document
                                    </button>
                                </div>
                            </div>
                        </form>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Mise à jour AJAX des disponibilités
        document.querySelectorAll('.availability-toggle').forEach(toggle => {
            toggle.addEventListener('change', function() {
                const day = this.getAttribute('data-day');
                const isActive = this.checked;
                fetch('/Provider/UpdateAvailability', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `day=${day}&isActive=${isActive}`
                }).then(res => { if(!res.ok) alert("Erreur réseau"); });
            });
        });
    </script>
}

