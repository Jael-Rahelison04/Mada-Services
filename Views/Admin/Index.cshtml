@model IEnumerable<MadaServices.Models.Provider>
@{
    ViewData["Title"] = "Modération - Vérifications";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-shield-lock me-2"></i>Modération des experts</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-light border rounded-4 p-5 text-center">
            <i class="bi bi-check-circle text-success display-4"></i>
            <p class="mt-3 mb-0">Aucune demande de vérification en attente. Beau travail !</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Prestataire</th>
                        <th>Métier</th>
                        <th>Ville</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pro in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@pro.FullName</div>
                                <small class="text-muted">ID: @pro.Id</small>
                            </td>
                            <td>@pro.JobTitle</td>
                            <td>@pro.City</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <form asp-action="VerifyProvider" asp-route-id="@pro.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">
                                            <i class="bi bi-check-lg"></i> Valider
                                        </button>
                                    </form>
                                    <form asp-action="RejectProvider" asp-route-id="@pro.Id" method="post">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="bi bi-x-lg"></i> Rejeter
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>