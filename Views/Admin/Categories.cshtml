@model IEnumerable<MadaServices.Models.Category>

<div class="container py-4">
    <div class="row">
        @* Formulaire d'ajout *@
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 24px;">
                <h5 class="fw-800 mb-4">Ajouter un métier</h5>
                <form asp-action="CreateCategory" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-700">Nom du métier</label>
                        <input name="name" class="form-control rounded-4 py-2" placeholder="Ex: Plombier" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-700">Icône (Bootstrap Icon)</label>
                        <input name="icon" class="form-control rounded-4 py-2" placeholder="Ex: bi-tools">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-700">Enregistrer</button>
                </form>
            </div>
        </div>

        @* Liste des catégories *@
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 24px;">
                <h5 class="fw-800 mb-4">Métiers enregistrés</h5>
                <div class="row g-3">
                    @foreach (var cat in Model)
                    {
                        <div class="col-sm-6">
                            <div class="d-flex justify-content-between align-items-center p-3 border rounded-4">
                                <span><i class="bi @cat.Icon me-2 text-primary"></i> @cat.Name</span>
                                <form asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post">
                                    <button type="submit" class="btn btn-sm text-danger"><i class="bi bi-trash3"></i></button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>