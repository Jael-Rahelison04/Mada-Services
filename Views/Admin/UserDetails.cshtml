@model MadaServices.Models.User

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --glass: rgba(255, 255, 255, 0.85);
        --glass-border: rgba(255, 255, 255, 0.6);
        --accent-gradient: linear-gradient(135deg, #6366f1 0%, #4338ca 100%);
        --danger-gradient: linear-gradient(135deg, #f87171 0%, #dc2626 100%);
        --success-gradient: linear-gradient(135deg, #34d399 0%, #059669 100%);
    }

    body {
        background: radial-gradient(circle at top right, #e2e8f0, #f1f5f9);
        min-height: 100vh;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .premium-card {
        background: var(--glass);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 35px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    }

    .info-box {
        background: rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.7);
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        height: 100%;
    }

    .info-box:hover {
        background: white;
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.03);
    }

    .avatar-detail {
        width: 120px; height: 120px;
        background: var(--accent-gradient);
        color: white; font-weight: 800;
        border-radius: 30px;
        display: flex; align-items: center; justify-content: center;
        font-size: 3rem;
        box-shadow: 0 15px 30px rgba(99, 102, 241, 0.3);
        margin: 0 auto 20px;
    }

    .status-badge {
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .btn-grad {
        border: none; color: white !important;
        padding: 16px 30px;
        font-weight: 700;
        transition: 0.3s;
        border-radius: 50px;
    }

    .btn-grad-danger { background: var(--danger-gradient); }
    .btn-grad-success { background: var(--success-gradient); }
    .btn-grad:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(0,0,0,0.15); }

    .label-custom {
        color: #64748b;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 6px;
        display: block;
        letter-spacing: 0.05em;
    }
</style>

<div class="container py-5">
    <div class="premium-card p-4 p-md-5">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <a asp-action="Index" class="btn btn-white shadow-sm rounded-pill px-4 border">
                <i class="bi bi-arrow-left me-2"></i>Dashboard
            </a>
            <div class="status-badge @(Model.LockoutEnd > DateTime.Now ? "bg-danger bg-opacity-10 text-danger" : "bg-success bg-opacity-10 text-success")">
                @(Model.LockoutEnd > DateTime.Now ? "Compte Suspendu" : "Compte Actif")
            </div>
        </div>

        <div class="row g-5">
            <div class="col-lg-4 text-center border-md-end border-white">
                <div class="avatar-detail">
                    @if(!string.IsNullOrEmpty(Model.FullName)) {
                        @Model.FullName[0].ToString().ToUpper()
                    } else {
                        <i class="bi bi-person"></i>
                    }
                </div>
                <h2 class="fw-bold mb-1">@(Model.FullName ?? "Utilisateur")</h2>
                <p class="text-primary fw-bold mb-4">@Model.Email</p>
                
                <div class="d-flex justify-content-center gap-2 mb-4">
                    <span class="badge bg-dark rounded-pill px-3 py-2">ID: #@(Model.Id.ToString().Length > 8 ? Model.Id.ToString().Substring(0,8) : Model.Id.ToString())</span>
                </div>
            </div>

            <div class="col-lg-8">
                <h5 class="fw-bold mb-4 text-dark">Informations Générales</h5>
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="info-box">
                            <span class="label-custom">Téléphone</span>
                            <span class="fw-bold d-block text-dark">@(Model.PhoneNumber ?? "Non renseigné")</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-box">
                            <span class="label-custom">Localisation</span>
                            <span class="fw-bold d-block text-dark">@(Model.Address ?? "Non renseignée")</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-box">
                            <span class="label-custom">Inscription</span>
                            <span class="fw-bold d-block text-dark">@Model.CreatedAt.ToString("dd MMMM yyyy")</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-box">
                            <span class="label-custom">Activité</span>
                            <span class="fw-bold text-muted small">Donnée indisponible</span>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top border-white">
                    <h5 class="fw-bold mb-2">Actions Administratives</h5>
                    <p class="text-muted small mb-4">
                        La suspension est réversible. Elle empêche l'accès immédiat à tous les services.
                    </p>

                    <form asp-action="ToggleUserStatus" asp-route-id="@Model.Id" method="post">
                        @if (Model.LockoutEnd > DateTime.Now)
                        {
                            <button type="submit" class="btn btn-grad btn-grad-success w-100">
                                <i class="bi bi-check2-circle me-2"></i>Lever la suspension
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-grad btn-grad-danger w-100" 
                                    onclick="return confirm('Suspendre cet utilisateur ?')">
                                <i class="bi bi-slash-circle me-2"></i>Suspendre l'accès
                            </button>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>