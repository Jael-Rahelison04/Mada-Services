@model IEnumerable<MadaServices.Models.Provider>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-800">Gestion des <span class="text-primary">Prestataires</span></h2>
        <span class="badge bg-dark rounded-pill px-3 py-2">@Model.Count() inscrits</span>
    </div>

    <div class="card border-0 shadow-sm p-4" style="border-radius: 24px;">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Prestataire</th>
                        <th>Métier</th>
                        <th>Documents</th>
                        <th>Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/images/default-avatar.png" : p.ImageUrl)" 
                                         class="rounded-circle me-3" style="width: 45px; height: 45px; object-fit: cover;">
                                    <div>
                                        <div class="fw-700">@p.FullName</div>
                                        <div class="small text-muted">@p.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-light text-dark border">@p.JobTitle</span></td>
                            <td>
                                @if (p.HasSubmittedDocs)
                                {
                                    <span class="text-success small fw-700"><i class="bi bi-file-check-fill"></i> Reçus</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Aucun document</span>
                                }
                            </td>
                            <td>
                                @if (p.IsVerified)
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3">Vérifié</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning rounded-pill px-3">Non vérifié</span>
                                }
                            </td>
                            <td class="text-end">
                                @if (!p.IsVerified && p.HasSubmittedDocs)
                                {
                                    <form asp-action="VerifyProvider" asp-route-id="@p.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 fw-700">
                                            Valider
                                        </button>
                                    </form>
                                }
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-700 ms-1">Suspendre</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>