@model IEnumerable<MadaServices.Models.Provider>

@{
    ViewData["Title"] = "Experts trouvés";
}

<style>
    :root {
        --indigo-main: #6c5ce7;
        --indigo-dark: #5649c1;
        --indigo-soft: #f0eeff;
        --emerald: #00b894;
    }

    /* --- Carte et Animation --- */
    .provider-card {
        border: 1px solid #f0f0f0;
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        background: white;
        overflow: hidden;
    }

    .provider-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(108, 92, 231, 0.12) !important;
        border-color: var(--indigo-main);
    }

    /* --- Avatar et Statut --- */
    .avatar-container {
        position: relative;
        width: 65px;
        height: 65px;
        flex-shrink: 0;
    }

    .avatar-circle {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, var(--indigo-main), #a29bfe);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        font-weight: 800;
        border-radius: 20px; /* Style plus moderne que le cercle parfait */
    }

    .status-badge {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 16px;
        height: 16px;
        background: var(--emerald);
        border: 3px solid white;
        border-radius: 50%;
    }

    /* --- Badges et Textes --- */
    .badge-verified {
        background: var(--indigo-soft);
        color: var(--indigo-main);
        font-size: 0.7rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 50px;
        text-uppercase: uppercase;
        letter-spacing: 0.5px;
    }

    .text-indigo { color: var(--indigo-main); }
    
    /* --- Portfolio Preview --- */
    .portfolio-img-wrapper {
        height: 80px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #f0f0f0;
    }

    .portfolio-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .portfolio-img-wrapper:hover img {
        transform: scale(1.1);
    }

    /* --- Boutons --- */
    .btn-view {
        background: var(--indigo-main);
        color: white;
        border-radius: 16px;
        font-weight: 700;
        border: none;
        transition: 0.3s;
    }

    .btn-view:hover {
        background: var(--indigo-dark);
        color: white;
        box-shadow: 0 8px 15px rgba(108, 92, 231, 0.3);
    }

    .price-tag {
        font-size: 1.3rem;
        font-weight: 800;
        color: #2d3436;
    }
</style>

<div class="container py-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h2 class="fw-800 mb-1">Experts disponibles</h2>
            <p class="text-muted mb-0">
                <i class="bi bi-geo-alt-fill text-indigo me-1"></i>
                <strong>@Model.Count()</strong> prestataire(s) trouvé(s) à Madagascar
            </p>
        </div>
        <a href="/" class="btn btn-light rounded-pill px-4 fw-600 shadow-sm border">
            <i class="bi bi-search me-2"></i> Nouvelle recherche
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-person-exclamation text-muted" style="font-size: 5rem; opacity: 0.3;"></i>
            </div>
            <h3 class="fw-800">Aucun expert trouvé</h3>
            <p class="text-muted">Nous n'avons trouvé personne correspondant à ces critères pour le moment.</p>
            <a href="/" class="btn btn-indigo px-5 rounded-pill mt-3">Retour à l'accueil</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var pro in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card provider-card h-100 p-3">
                        <div class="card-body d-flex flex-column">
                            
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-container me-3">
                                    @if (!string.IsNullOrEmpty(pro.ProfileImageUrl)) {
                                        <img src="@pro.ProfileImageUrl" class="avatar-circle" style="object-fit: cover;">
                                    } else {
                                        <div class="avatar-circle">
                                            <span>@pro.FullName.Substring(0, 1).ToUpper()</span>
                                        </div>
                                    }
                                    <div class="status-badge"></div>
                                </div>
                                <div class="overflow-hidden">
                                    <h5 class="fw-800 mb-0 text-truncate">@pro.FullName</h5>
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <small class="text-muted"><i class="bi bi-geo-alt"></i> @pro.City</small>
                                        @if (pro.IsVerified)
                                        {
                                            <span class="badge-verified">
                                                <i class="bi bi-patch-check-fill me-1"></i>Vérifié
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <h6 class="text-indigo fw-800 mb-2">@pro.JobTitle</h6>
                            <p class="text-muted small mb-4">
                                @(pro.Description?.Length > 95 ? pro.Description.Substring(0, 95) + "..." : pro.Description)
                            </p>

                            @if (pro.PortfolioItems != null && pro.PortfolioItems.Any())
                            {
                                <div class="row g-2 mb-4">
                                    @foreach (var item in pro.PortfolioItems.Take(3))
                                    {
                                        <div class="col-4">
                                            <div class="portfolio-img-wrapper">
                                                <img src="@item.ImageUrl" alt="Réalisation">
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-end mb-3">
                                    @{
                                        var avg = (pro.Reviews != null && pro.Reviews.Any()) ? pro.Reviews.Average(r => r.Rating) : 0;
                                    }
                                    <div>
                                        <div class="text-warning small mb-1">
                                            @for(int i=1; i<=5; i++) {
                                                <i class="bi @(i <= Math.Round(avg) ? "bi-star-fill" : "bi-star text-muted opacity-25")"></i>
                                            }
                                        </div>
                                        <span class="text-muted x-small">(@(pro.Reviews?.Count ?? 0) avis)</span>
                                    </div>
                                    <div class="text-end">
                                        <div class="price-tag">@pro.HourlyRate.ToString("N0") <small style="font-size: 0.7rem; font-weight: 600;">Ar/h</small></div>
                                    </div>
                                </div>

                                <a asp-action="Details" asp-route-id="@pro.Id" class="btn btn-view w-100 py-3">
                                    Consulter le Profil
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>