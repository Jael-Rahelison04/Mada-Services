@model IEnumerable<MadaServices.Models.Provider>

@{
    ViewData["Title"] = "Experts trouvés";
}

<style>
    .provider-card {
        border: none;
        border-radius: 20px;
        transition: all 0.3s ease;
        background: white;
        overflow: hidden;
    }
    .provider-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .avatar-circle {
        width: 55px;
        height: 55px;
        background: linear-gradient(45deg, #6c5ce7, #a29bfe);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        font-weight: bold;
        border-radius: 50%;
    }
    .badge-verified {
        background: #00b894;
        color: white;
        font-size: 0.75rem;
        padding: 4px 12px;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
    }
    .portfolio-preview img {
        width: 100%;
        height: 70px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid #f0f0f0;
    }
    .text-indigo { color: #6c5ce7; }
    .btn-view {
        background: #6c5ce7;
        color: white;
        border-radius: 50px;
        font-weight: 600;
        border: none;
    }
    .btn-view:hover { background: #5649c1; color: white; }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-0">Experts disponibles</h2>
            <p class="text-muted">@Model.Count() prestataire(s) trouvé(s) à Madagascar</p>
        </div>
        <a href="/" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Nouvelle recherche
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search text-muted display-1"></i>
            <h3 class="mt-3">Aucun résultat</h3>
            <p class="text-muted">Essayez d'élargir votre recherche.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var pro in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card provider-card shadow-sm h-100 p-3">
                        <div class="card-body d-flex flex-column">
                            
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-circle me-3">
                                    @pro.FullName.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0">@pro.FullName</h5>
                                    <div class="d-flex align-items-center">
                                        <small class="text-muted me-2"><i class="bi bi-geo-alt-fill"></i> @pro.City</small>
                                        @if (pro.IsVerified)
                                        {
                                            <span class="badge-verified"><i class="bi bi-patch-check-fill me-1"></i> Vérifié</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <h6 class="text-indigo fw-bold">@pro.JobTitle</h6>
                            <p class="text-muted small mb-3">
                                @(pro.Description?.Length > 90 ? pro.Description.Substring(0, 90) + "..." : pro.Description)
                            </p>

                            @if (pro.PortfolioImages != null && pro.PortfolioImages.Any())
                            {
                                <div class="row g-1 mb-3 portfolio-preview">
                                    @foreach (var img in pro.PortfolioImages.Take(3))
                                    {
                                        <div class="col-4">
                                            <img src="@img" alt="Travail de @pro.FullName">
                                        </div>
                                    }
                                </div>
                            }

                            <div class="mt-auto mb-3">
                                @{
                                    var avg = pro.Reviews != null && pro.Reviews.Any() ? pro.Reviews.Average(r => r.Rating) : 0;
                                }
                                <div class="text-warning small">
                                    <i class="bi @(avg >= 1 ? "bi-star-fill" : "bi-star")"></i>
                                    <span class="text-dark fw-bold ms-1">@avg.ToString("0.0")</span>
                                    <span class="text-muted ms-1">(@(pro.Reviews?.Count ?? 0) avis)</span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold fs-5 text-dark">@pro.HourlyRate.ToString("N0") Ar<small class="text-muted fw-normal">/h</small></span>
                                <a asp-action="Details" asp-route-id="@pro.Id" class="btn btn-view px-4 py-2">Voir le profil</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>