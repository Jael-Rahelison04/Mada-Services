@model IEnumerable<MadaServices.Models.Provider>
@{
    ViewData["Title"] = "Premium Experts - MadaServices";
    var categories = Model.Select(p => p.JobTitle).Distinct().OrderBy(c => c).ToList();
}

<style>
    :root {
        --brand-main: #4338ca;
        --brand-accent: #6366f1;
        --brand-success: #10b981;
        --brand-dark: #0f172a;
        --brand-light: #f8fafc;
        --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.04), 0 8px 10px -6px rgba(0, 0, 0, 0.04);
    }

    body { background-color: #fcfcfd; }

    /* --- Barre de Recherche "Floating" --- */
    .search-pill {
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0 !important;
        backdrop-filter: blur(8px);
    }
    .search-pill:focus-within {
        border-color: var(--brand-main) !important;
        box-shadow: 0 0 0 4px rgba(67, 56, 202, 0.1) !important;
    }

    /* --- Navigation Catégories --- */
    .category-scroll {
        display: flex;
        overflow-x: auto;
        gap: 12px;
        padding: 15px 5px;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }
    .category-scroll::-webkit-scrollbar { display: none; }

    .cat-item {
        background: white;
        padding: 10px 20px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        cursor: pointer;
        white-space: nowrap;
        transition: 0.2s all ease;
        font-size: 0.9rem;
        font-weight: 500;
        color: #64748b;
    }

    .cat-item:hover {
        background: var(--brand-light);
        color: var(--brand-main);
    }

    .cat-item.active {
        background: var(--brand-dark);
        color: white;
        border-color: var(--brand-dark);
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
    }

    /* --- Cartes Experts --- */
    .pro-card {
        border-radius: 20px;
        border: 1px solid rgba(0,0,0,0.03);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
    }

    .pro-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .avatar-block {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        object-fit: cover;
        border: 2px solid white;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }

    .job-tag {
        background: #eef2ff;
        color: var(--brand-main);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.7rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-weight: 700;
    }

    .status-dot {
        position: absolute;
        bottom: -2px;
        right: -2px;
        width: 14px;
        height: 14px;
        background: var(--brand-success);
        border: 3px solid white;
        border-radius: 50%;
    }

    /* --- Sidebar de Filtre --- */
    .filter-sidebar {
        position: sticky;
        top: 20px;
    }

    .filter-price.active-price {
        background-color: var(--brand-main) !important;
        color: white !important;
        border-color: var(--brand-main) !important;
    }

    /* Animation */
    .pro-item { transition: opacity 0.4s ease, transform 0.4s ease; }
    .filtered-out { opacity: 0; transform: scale(0.95); display: none; }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="fw-900 text-dark mb-3">Trouvez l'expert idéal</h2>
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="search-pill d-flex align-items-center bg-white p-2 rounded-pill">
                    <i class="bi bi-search ms-3 text-muted"></i>
                    <input type="text" id="premiumSearch" class="form-control border-0 shadow-none bg-transparent" placeholder="Nom, spécialité ou ville...">
                    <button class="btn btn-dark rounded-pill px-4 py-2 fw-bold ms-2">Rechercher</button>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-5">
        <div class="category-scroll px-2">
            <div class="cat-item active" data-category="all">Tous les services</div>
            @foreach (var cat in categories)
            {
                <div class="cat-item" data-category="@cat.ToLower()">@cat</div>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="filter-sidebar bg-white rounded-4 p-4 border">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold m-0">Filtres avancés</h6>
                    <button class="btn btn-link btn-sm text-decoration-none p-0" id="resetAll">Effacer</button>
                </div>
                
                <label class="small fw-bold text-muted mb-3 d-block text-uppercase">Budget horaire</label>
                <div class="d-grid gap-2 mb-4">
                    <button class="btn btn-outline-light text-dark border btn-sm text-start py-2 px-3 filter-price" data-max="30000">Économique (< 30k)</button>
                    <button class="btn btn-outline-light text-dark border btn-sm text-start py-2 px-3 filter-price" data-min="30000" data-max="70000">Standard (30k-70k)</button>
                    <button class="btn btn-outline-light text-dark border btn-sm text-start py-2 px-3 filter-price" data-min="70000">Premium (> 70k)</button>
                </div>

                <label class="small fw-bold text-muted mb-2 d-block text-uppercase">Tri</label>
                <select id="premiumSort" class="form-select border-0 bg-light shadow-none">
                    <option value="default">Pertinence</option>
                    <option value="price-asc">Prix croissant</option>
                    <option value="price-desc">Prix décroissant</option>
                </select>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="row g-4" id="premiumGrid">
                @foreach (var pro in Model)
                {
                    var avg = (pro.Reviews != null && pro.Reviews.Any()) ? pro.Reviews.Average(r => r.Rating) : 0;

                    <div class="col-md-6 col-xl-4 pro-item" 
                         data-price="@pro.HourlyRate" 
                         data-category="@pro.JobTitle.ToLower()"
                         data-tags="@pro.FullName.ToLower() @pro.JobTitle.ToLower() @pro.City.ToLower()">
                        
                        <div class="pro-card shadow-sm h-100 bg-white">
                            <div class="p-4 d-flex flex-column h-100">
                                <div class="d-flex justify-content-between mb-3">
                                    <div class="position-relative">
                                        <img src="@(string.IsNullOrEmpty(pro.ProfileImageUrl) ? "/images/default-avatar.png" : pro.ProfileImageUrl)" class="avatar-block" alt="@pro.FullName">
                                        <div class="status-dot"></div>
                                    </div>
                                    <div class="text-end">
                                        <div class="rating-tag text-warning small fw-bold">
                                            <i class="bi bi-star-fill"></i> @(avg > 0 ? avg.ToString("F1") : "Nouveau")
                                        </div>
                                        <span class="text-muted" style="font-size: 0.7rem;">(@(pro.Reviews?.Count() ?? 0) avis)</span>
                                    </div>
                                </div>

                                <h6 class="fw-bold mb-1 text-dark">@pro.FullName</h6>
                                <div class="mb-3"><span class="job-tag">@pro.JobTitle</span></div>
                                
                                <p class="text-muted small mb-4 flex-grow-1">
                                    <i class="bi bi-geo-alt me-1"></i> @pro.City<br>
                                    <span class="d-inline-block mt-2">@pro.Description</span>
                                </p>

                                <div class="pt-3 border-top d-flex align-items-center justify-content-between">
                                    <div>
                                        <span class="fw-900 text-primary fs-5">@pro.HourlyRate.ToString("N0")</span>
                                        <span class="text-muted small">Ar/h</span>
                                    </div>
                                    <a asp-action="Details" asp-route-id="@pro.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3 fw-bold">Profil</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const items = Array.from(document.querySelectorAll('.pro-item'));
        const searchInput = document.getElementById('premiumSearch');
        const catItems = document.querySelectorAll('.cat-item');
        const priceButtons = document.querySelectorAll('.filter-price');
        
        let currentFilters = {
            search: '',
            category: 'all',
            price: { min: 0, max: Infinity }
        };

        function applyAllFilters() {
            items.forEach(item => {
                const matchesSearch = item.dataset.tags.includes(currentFilters.search);
                const matchesCat = currentFilters.category === 'all' || item.dataset.category === currentFilters.category;
                const price = parseFloat(item.dataset.price);
                const matchesPrice = price >= currentFilters.price.min && price <= currentFilters.price.max;

                item.classList.toggle('filtered-out', !(matchesSearch && matchesCat && matchesPrice));
            });
        }

        catItems.forEach(cat => {
            cat.addEventListener('click', function() {
                catItems.forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                currentFilters.category = this.dataset.category;
                applyAllFilters();
            });
        });

        searchInput.addEventListener('input', (e) => {
            currentFilters.search = e.target.value.toLowerCase();
            applyAllFilters();
        });

        priceButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                const isActive = this.classList.contains('active-price');
                priceButtons.forEach(b => b.classList.remove('active-price'));
                
                if (!isActive) {
                    this.classList.add('active-price');
                    currentFilters.price.min = parseFloat(this.dataset.min) || 0;
                    currentFilters.price.max = parseFloat(this.dataset.max) || Infinity;
                } else {
                    currentFilters.price = { min: 0, max: Infinity };
                }
                applyAllFilters();
            });
        });

        document.getElementById('resetAll').onclick = () => {
            currentFilters = { search: '', category: 'all', price: { min: 0, max: Infinity } };
            searchInput.value = '';
            catItems.forEach(c => c.classList.remove('active'));
            document.querySelector('[data-category="all"]').classList.add('active');
            priceButtons.forEach(b => b.classList.remove('active-price'));
            applyAllFilters();
        };

        document.getElementById('premiumSort').onchange = function() {
            const grid = document.getElementById('premiumGrid');
            const sorted = [...items].sort((a, b) => {
                const pA = parseFloat(a.dataset.price);
                const pB = parseFloat(b.dataset.price);
                return this.value === 'price-asc' ? pA - pB : pB - pA;
            });
            sorted.forEach(el => grid.appendChild(el));
        };
    });
</script>