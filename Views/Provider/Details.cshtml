@model MadaServices.Models.Provider
@{
    ViewData["Title"] = Model.FullName;
    bool canSeeContact = User.Identity?.IsAuthenticated ?? false;
}

<style>
    :root {
        --brand-primary: #059669;
        --brand-secondary: #2563eb;
        --brand-gradient: linear-gradient(135deg, #059669 0%, #2563eb 100%);
    }

    .profile-header-card { 
        background: white; 
        border-radius: 24px; 
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.05); 
        border: 1px solid rgba(0,0,0,0.03);
    }

    .avatar-box { 
        width: 120px; 
        height: 120px; 
        background: var(--brand-gradient); 
        color: white; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        border-radius: 24px; 
        overflow: hidden;
        font-size: 3rem;
        font-weight: bold;
    }

    .avatar-img { width: 100%; height: 100%; object-fit: cover; }

    .status-badge { 
        padding: 6px 16px; 
        border-radius: 50px; 
        font-size: 0.8rem; 
        font-weight: 700; 
        text-transform: uppercase;
    }
    .status-active { background: #dcfce7; color: #166534; }
    .status-paused { background: #fee2e2; color: #991b1b; }

    .availability-badge {
        flex: 1;
        text-align: center;
        padding: 12px 8px;
        border-radius: 15px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        transition: 0.3s;
    }
    .availability-badge.active {
        background: #ecfdf5;
        border-color: #10b981;
        color: #059669;
    }

    .portfolio-img {
        height: 200px;
        width: 100%;
        object-fit: cover;
        border-radius: 15px;
        transition: transform 0.3s ease;
    }
    .portfolio-img:hover { transform: scale(1.03); }

    .btn-primary-mada { 
        background: var(--brand-gradient); 
        border: none; 
        color: white; 
        border-radius: 14px; 
        padding: 14px; 
        font-weight: 700; 
        transition: 0.3s;
    }
    .btn-primary-mada:hover { opacity: 0.9; transform: translateY(-2px); color: white; }
</style>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="profile-header-card p-4 p-md-5 mb-4 position-relative">
                <div class="position-absolute top-0 end-0 m-4">
                    @if (Model.IsPaused) {
                        <span class="status-badge status-paused"><i class="bi bi-circle-fill me-1 small"></i> En pause</span>
                    } else {
                        <span class="status-badge status-active"><i class="bi bi-circle-fill me-1 small"></i> Disponible</span>
                    }
                </div>

                <div class="d-flex flex-column flex-md-row align-items-center align-items-md-start gap-4">
                    <div class="avatar-box shadow-sm">
                        @if (!string.IsNullOrEmpty(Model.ProfileImageUrl)) {
                            <img src="@Model.ProfileImageUrl" class="avatar-img" alt="@Model.FullName" />
                        } else {
                            <span>@Model.FullName?[0]</span>
                        }
                    </div>
                    <div class="text-center text-md-start flex-grow-1">
                        <span class="badge bg-light text-primary border mb-2 px-3 py-2 rounded-pill fw-bold">
                            <i class="bi bi-briefcase me-1"></i> @(Model.JobTitle ?? "Prestataire")
                        </span>
                        <h1 class="fw-800 text-dark mb-1">@Model.FullName</h1>
                        <p class="text-muted fs-5"><i class="bi bi-geo-alt-fill text-danger me-1"></i> @(Model.City ?? "Non spécifiée")</p>
                        
                        <div class="d-flex justify-content-center justify-content-md-start gap-4 mt-3">
                            <div class="text-center">
                                <span class="d-block fw-bold fs-4">@Model.AverageRating.ToString("F1") <i class="bi bi-star-fill text-warning"></i></span>
                                <span class="text-muted small">Note moyenne</span>
                            </div>
                            <div class="vr"></div>
                            <div class="text-center text-md-start">
                                <span class="d-block fw-bold fs-4 text-success">
                                    @(Model.HourlyRate > 0 ? $"{Model.HourlyRate:N0} Ar/h" : "Sur devis")
                                </span>
                                <span class="text-muted small">Tarif horaire</span>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4 opacity-5">
                <h5 class="fw-bold text-dark mb-3">À propos</h5>
                <p class="text-muted lh-lg">@(Model.Description ?? "Ce prestataire n'a pas encore ajouté de description.")</p>
            </div>

            <div class="profile-header-card p-4 p-md-5 mb-4">
                <h5 class="fw-bold mb-4"><i class="bi bi-clock me-2 text-primary"></i>Disponibilités</h5>
                <div class="d-flex flex-wrap gap-2">
                    @{
                        var joursSemaine = new[] { "Lun", "Mar", "Mer", "Jeu", "Ven", "Sam", "Dim" };
                        foreach (var j in joursSemaine)
                        {
                            var dispos = Model.Availabilities?.Any(a => a.DayOfWeek == j && a.IsActive) ?? false;
                            <div class="availability-badge @(dispos ? "active" : "")">
                                <div class="fw-bold">@j</div>
                                <div class="small">@(dispos ? "Dispo" : "-")</div>
                            </div>
                        }
                    }
                </div>
            </div>

            @if (Model.PortfolioItems != null && Model.PortfolioItems.Any())
            {
                <div class="profile-header-card p-4 p-md-5 mb-4">
                    <h5 class="fw-bold mb-4"><i class="bi bi-grid-3x3-gap me-2 text-primary"></i>Portfolio & Réalisations</h5>
                    <div class="row g-3">
                        @foreach (var item in Model.PortfolioItems)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                    <img src="@item.ImageUrl" class="portfolio-img" alt="Travail">
                                    @if (!string.IsNullOrEmpty(item.Description)) {
                                        <div class="card-body p-2 bg-light">
                                            <p class="card-text small text-muted text-truncate mb-0">@item.Description</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="profile-header-card p-4 p-md-5">
                <h5 class="fw-bold mb-4"><i class="bi bi-chat-left-quote me-2 text-primary"></i>Avis clients</h5>
                @if (Model.Reviews != null && Model.Reviews.Any()) {
                    @foreach (var r in Model.Reviews.OrderByDescending(x => x.DatePosted)) {
                        <div class="p-3 mb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="text-dark">@r.CustomerName</strong>
                                <span class="text-warning small">
                                    @for(int i=1; i<=5; i++) { <i class="bi bi-star@(i <= r.Rating ? "-fill" : "")"></i> }
                                </span>
                            </div>
                            <p class="text-muted small mb-1 italic">"@r.Comment"</p>
                            <span class="text-muted" style="font-size: 0.7rem;">@r.DatePosted.ToString("dd/MM/yyyy")</span>
                        </div>
                    }
                } else {
                    <div class="text-center py-4">
                        <i class="bi bi-chat-dots display-6 text-light"></i>
                        <p class="text-muted mt-2">Aucun avis pour le moment.</p>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="profile-header-card p-4 sticky-top" style="top: 100px;">
                <h5 class="fw-bold text-dark mb-4">Contacter @Model.FullName.Split(' ')[0]</h5>
                
                @if (canSeeContact) {
                    <div class="bg-light p-3 rounded-4 mb-4 text-center">
                        <p class="text-muted small mb-1">Numéro de contact</p>
                        <h4 class="fw-800 text-primary mb-0">@(Model.PhoneNumber ?? "Non fourni")</h4>
                    </div>

                    <div class="d-grid gap-3">
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber) && !Model.IsPaused) {
                            <a href="tel:@Model.PhoneNumber" class="btn btn-primary-mada">
                                <i class="bi bi-telephone-fill me-2"></i> Appeler
                            </a>
                        }
                        <button class="btn btn-outline-dark rounded-4 fw-bold py-3">
                            <i class="bi bi-envelope me-2"></i> Envoyer un message
                        </button>
                    </div>
                } else {
                    <div class="text-center p-3">
                        <div class="bg-soft-primary p-3 rounded-4 mb-3">
                            <i class="bi bi-lock-fill text-primary fs-1"></i>
                        </div>
                        <p class="text-muted small mb-4">Vous devez être connecté pour voir le numéro de téléphone.</p>
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-primary-mada w-100">
                            Se connecter
                        </a>
                    </div>
                }
                
                <div class="mt-4 p-3 bg-light rounded-4">
                    <p class="small text-muted mb-0">
                        <i class="bi bi-shield-check text-success me-1"></i> MadaServices protège vos données.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>