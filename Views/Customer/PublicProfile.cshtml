@model MadaServices.Models.User

@{
    ViewData["Title"] = "Profil de " + Model.FullName;
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body { 
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); 
        font-family: 'Outfit', sans-serif; 
        min-height: 100vh;
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 40px;
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        margin-top: 50px;
    }

    .banner {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        height: 160px;
        position: relative;
    }

    .avatar-wrapper {
        position: relative;
        margin-top: -80px;
        z-index: 5;
    }

    .avatar-img {
        width: 160px;
        height: 160px;
        border-radius: 45px;
        object-fit: cover;
        border: 8px solid white;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        background: #f1f5f9;
    }

    .stat-box {
        background: #f8fafc;
        border-radius: 20px;
        padding: 20px;
        transition: 0.3s;
        border: 1px solid transparent;
    }
    .stat-box:hover {
        background: white;
        border-color: #e2e8f0;
        transform: translateY(-5px);
    }

    .btn-contact {
        background: #4f46e5;
        color: white;
        border: none;
        border-radius: 20px;
        padding: 18px;
        font-weight: 700;
        transition: 0.3s;
        box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.4);
    }
    .btn-contact:hover {
        background: #3730a3;
        color: white;
        transform: scale(1.02);
    }

    .badge-verified {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        border-radius: 12px;
        padding: 6px 16px;
        font-weight: 700;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="profile-card">
                @* Bannière supérieure *@
                <div class="banner">
                    <div class="p-4 text-end">
                        <span class="badge-verified">
                            <i class="bi bi-patch-check-fill me-2"></i>Profil Vérifié
                        </span>
                    </div>
                </div>

                <div class="text-center px-4">
                    @* Avatar *@
                    <div class="avatar-wrapper">
                        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-avatar.png" : Model.ImageUrl)" 
                             class="avatar-img" alt="@Model.FullName">
                    </div>

                    @* Infos principales *@
                    <h1 class="fw-800 mt-4 mb-1">@Model.FullName</h1>
                    <p class="text-muted mb-4">
                        <i class="bi bi-geo-alt-fill text-danger me-1"></i> 
                        @(Model.Address ?? "Madagascar")
                    </p>

                    @* Grille d'informations *@
                    <div class="row g-3 mb-5 mt-2">
                        <div class="col-sm-6">
                            <div class="stat-box h-100">
                                <i class="bi bi-envelope-at fs-3 text-primary mb-2"></i>
                                <div class="small text-muted mb-1">Email Officiel</div>
                                <div class="fw-bold text-truncate px-2">@Model.Email</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="stat-box h-100">
                                <i class="bi bi-phone-vibrate fs-3 text-primary mb-2"></i>
                                <div class="small text-muted mb-1">Téléphone</div>
                                <div class="fw-bold">@(Model.Phone ?? "Non renseigné")</div>
                            </div>
                        </div>
                    </div>

                    @* Actions *@
                    <div class="pb-5 px-md-5">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <a href="mailto:@Model.Email" class="btn-contact w-100 d-block text-decoration-none">
                                    <i class="bi bi-chat-dots-fill me-2"></i>Envoyer un message
                                </a>
                            </div>
                            <div class="col-md-6">
                                <button onclick="window.print()" class="btn btn-light w-100 rounded-4 py-3 fw-700 border text-muted">
                                    <i class="bi bi-printer-fill me-2"></i>Imprimer CV/Profil
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            @* Petit footer discret *@
            <p class="text-center mt-4 text-muted small">
                Membre MadaServices depuis @Model.CreatedAt.ToString("MMMM yyyy")
            </p>
        </div>
    </div>
</div>