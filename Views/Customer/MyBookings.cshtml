@model IEnumerable<MadaServices.Models.Booking>

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --primary: #6366f1;
        --primary-soft: #eef2ff;
        --bg-main: #f8fafc;
        --border-color: #e2e8f0;
    }

    body { 
        background-color: var(--bg-main); 
        font-family: 'Outfit', sans-serif; 
        color: #1e293b; 
    }

    /* --- EN-TÊTE --- */
    .page-header {
        background: white;
        border-radius: 24px;
        padding: 30px;
        border: 1px solid var(--border-color);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.02);
        margin-bottom: 30px;
    }

    /* --- TABLEAU STYLE PREMIUM --- */
    .glass-card {
        background: white;
        border-radius: 28px;
        border: 1px solid var(--border-color);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .table thead th {
        background-color: #fcfcfd;
        text-transform: uppercase;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #64748b;
        padding: 20px;
        border-bottom: 1px solid var(--border-color);
    }

    .table tbody td {
        padding: 20px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }

    .table tr:hover {
        background-color: #f8fafc;
    }

    /* --- BADGES DE STATUT --- */
    .status-pill {
        padding: 6px 14px;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-accepted { background: #dcfce7; color: #15803d; }
    .status-pending { background: #fef9c3; color: #854d0e; }
    .status-completed { background: #e0e7ff; color: #4338ca; }
    .status-canceled { background: #fee2e2; color: #b91c1c; }

    .price-tag {
        color: var(--primary);
        font-weight: 800;
        font-size: 1.05rem;
    }

    .empty-state {
        padding: 80px 20px;
        text-align: center;
    }

    .empty-state i {
        font-size: 4rem;
        background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 20px;
    }
</style>

<div class="container py-5">
    <div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Tableau de bord</a></li>
                    <li class="breadcrumb-item active fw-600 text-primary">Mes Demandes</li>
                </ol>
            </nav>
            <h2 class="fw-800 mb-0">Historique des services</h2>
        </div>
        <a asp-action="Index" class="btn btn-white border rounded-pill px-4 fw-700 shadow-sm transition-all hover-up">
            <i class="bi bi-arrow-left me-2"></i>Retour
        </a>
    </div>

    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Service & Détails</th>
                        <th>Date de demande</th>
                        <th>Prix Estimé</th>
                        <th>État du service</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any()) {
                        foreach (var b in Model) {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary-soft text-primary rounded-3 p-2 me-3">
                                            <i class="bi bi-tools fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-800 text-dark">@b.ServiceName</div>
                                            <div class="text-muted small">ID de commande : #@b.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-600 text-dark">@b.CreatedAt.ToString("dd MMM yyyy")</div>
                                    <div class="text-muted small">@b.CreatedAt.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    <span class="price-tag">@b.TotalPrice.ToString("N0") <small>Ar</small></span>
                                </td>
                                <td>
                                    @{
                                        var statusClass = b.Status switch {
                                            "Accepted" => "status-accepted",
                                            "Pending" => "status-pending",
                                            "Completed" => "status-completed",
                                            _ => "status-canceled"
                                        };
                                        var statusIcon = b.Status switch {
                                            "Accepted" => "bi-check-circle-fill",
                                            "Pending" => "bi-hourglass-split",
                                            "Completed" => "bi-flag-fill",
                                            _ => "bi-x-circle-fill"
                                        };
                                    }
                                    <span class="status-pill @statusClass">
                                        <i class="bi @statusIcon"></i> @b.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-light btn-sm rounded-pill px-3 fw-700 border">
                                        Détails
                                    </button>
                                </td>
                            </tr>
                        }
                    } else {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-chat-square-quote"></i>
                                    <h4 class="fw-800 text-dark">Aucune demande trouvée</h4>
                                    <p class="text-muted mx-auto" style="max-width: 400px;">
                                        Vous n'avez pas encore sollicité d'experts. Trouvez le prestataire idéal pour vos travaux dès maintenant !
                                    </p>
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 fw-700 mt-3">
                                        Explorer les services
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>