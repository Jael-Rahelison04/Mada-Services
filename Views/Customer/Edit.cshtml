@model MadaServices.Models.EditProfileViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-indigo p-4 text-center text-white">
                    <h3 class="fw-bold mb-0">Modifier mon profil</h3>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="text-center mb-5">
                            <div class="position-relative d-inline-block">
                                <img src="@(Model.ExistingPhotoPath ?? "/images/default-user.png")" 
                                     id="previewImg" class="rounded-circle shadow" 
                                     style="width: 120px; height: 120px; object-fit: cover; border: 4px solid white;">
                                <label for="photoInput" class="btn btn-sm btn-vibrant position-absolute bottom-0 end-0 rounded-circle p-2">
                                    <i class="bi bi-camera-fill"></i>
                                </label>
                                <input type="file" id="photoInput" name="PhotoFile" class="d-none" accept="image/*">
                            </div>
                            <p class="small text-muted mt-2">Cliquez sur l'icône pour changer la photo</p>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Nom complet</label>
                                <input asp-for="FullName" class="form-control rounded-3 bg-light border-0 p-3" placeholder="Ex: Jean Rakoto">
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Ville</label>
                                <select asp-for="City" class="form-select rounded-3 bg-light border-0 p-3">
                                    <option value="Antananarivo">Antananarivo</option>
                                    <option value="Antsirabe">Antsirabe</option>
                                    <option value="Toamasina">Toamasina</option>
                                    <option value="Mahajanga">Mahajanga</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Téléphone</label>
                                <input asp-for="PhoneNumber" class="form-control rounded-3 bg-light border-0 p-3" placeholder="034 XX XXX XX">
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-vibrant py-3">Enregistrer les modifications</button>
                            <a asp-action="Index" class="btn btn-link text-muted">Retour au tableau de bord</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Aperçu de l'image en temps réel
        document.getElementById('photoInput').onchange = evt => {
            const [file] = document.getElementById('photoInput').files
            if (file) {
                document.getElementById('previewImg').src = URL.createObjectURL(file)
            }
        }
    </script>
}

<style>
    .bg-indigo { background: linear-gradient(135deg, #6c5ce7, #a29bfe); }
    .form-control:focus, .form-select:focus {
        background-color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(108, 92, 231, 0.1);
        border: 1px solid #6c5ce7 !important;
    }
</style>