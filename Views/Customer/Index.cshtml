@model IEnumerable<MadaServices.Models.Review>
@{
    ViewData["Title"] = "Espace Client";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root { --primary: #4f46e5; --bg: #f8fafc; --card: #ffffff; }
    body { background: var(--bg); font-family: 'Outfit', sans-serif; color: #1e293b; }

    /* HEADER */
    .dash-header { background: var(--card); padding: 15px 0; border-bottom: 1px solid #e2e8f0; margin-bottom: 25px; }
    .date-text { font-size: 0.75rem; color: #64748b; font-weight: 600; text-transform: uppercase; }
    
    /* CARDS */
    .stat-box { 
        background: var(--card); border-radius: 18px; padding: 20px; 
        border: 1px solid #e2e8f0; transition: 0.2s; height: 100%;
    }
    .stat-box:hover { border-color: var(--primary); }
    .icon-sm { font-size: 1.2rem; margin-bottom: 10px; display: block; }

    /* BUTTONS */
    .btn-action { 
        background: var(--primary); color: white !important; border-radius: 10px; 
        padding: 8px 16px; font-weight: 700; font-size: 0.8rem; border: none; text-decoration: none;
    }
    .link-flat { font-size: 0.75rem; font-weight: 700; color: var(--primary); text-decoration: none; text-transform: uppercase; cursor: pointer; }

    /* TABLE */
    .table-card { background: var(--card); border-radius: 18px; border: 1px solid #e2e8f0; overflow: hidden; }
    .table thead th { font-size: 0.65rem; text-transform: uppercase; color: #94a3b8; padding: 12px 20px; }
    .table td { padding: 12px 20px; font-size: 0.85rem; }

    /* CONTACT STYLE */
    .contact-link { color: #10b981; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 5px; }
    .contact-link:hover { color: #059669; }

    /* INPUTS */
    .form-custom { background: #f1f5f9; border: none; border-radius: 10px; padding: 10px; font-size: 0.85rem; }
</style>

<div class="dash-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <div class="date-text">@DateTime.Now.ToString("dd MMM yyyy")</div>
            <h5 class="fw-800 mb-0">@User.Identity?.Name</h5>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-light btn-sm rounded-pill fw-700 border">
            <i class="bi bi-plus-lg me-1"></i> Nouveau projet
        </a>
    </div>
</div>

<div class="container">
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-box">
                <i class="bi bi-clock-history text-primary icon-sm"></i>
                <div class="d-flex justify-content-between align-items-end">
                    <h6 class="fw-700 mb-0">Activités</h6>
                    <a asp-action="MyBookings" class="link-flat">Historique</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-box">
                <i class="bi bi-star-fill text-warning icon-sm"></i>
                <div class="d-flex justify-content-between align-items-end">
                    <h6 class="fw-700 mb-0">@(ViewBag.TotalReviews ?? 0) Avis</h6>
                    <span class="link-flat" data-bs-toggle="modal" data-bs-target="#reviewModal">Ajouter un avis</span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-box">
                <i class="bi bi-whatsapp text-success icon-sm"></i>
                <div class="d-flex justify-content-between align-items-end">
                    <h6 class="fw-700 mb-0">Aide</h6>
                    <a href="https://wa.me/261340000000" class="link-flat">Contact Support</a>
                </div>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="p-3 border-bottom"><span class="fw-800 small text-uppercase">Contacts Récents</span></div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Métier</th>
                        <th>Contact</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.ProvidersList != null) {
                        foreach (var p in ViewBag.ProvidersList) {
                            <tr>
                                <td class="fw-600">@p.FullName</td>
                                <td class="text-muted">@p.JobTitle</td>
                                <td>
                                    <a href="https://wa.me/@p.PhoneNumber" class="contact-link" target="_blank">
                                        <i class="bi bi-whatsapp"></i> @p.PhoneNumber
                                    </a>
                                </td>
                                <td class="text-end">
                                    <button class="btn-action" onclick="openBookingModal('@p.Id', '@p.FullName', '@p.PhoneNumber')">Réserver</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
            <div class="modal-header border-0 px-4 pt-4 pb-0">
                <h5 class="fw-800 mb-0">
                    <i class="bi bi-star-fill text-warning me-2"></i>Noter un expert
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <form asp-action="CreateReview" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">

                        <div class="col-md-5">

                            <div class="mb-4">
                                <label class="small fw-700 text-muted d-block mb-2">
                                    PRESTATAIRE
                                </label>
                                <select name="providerId"
                                        class="form-select form-custom"
                                        required>
                                    @if (ViewBag.ProvidersList != null) {
                                        foreach (var p in ViewBag.ProvidersList) {
                                            <option value="@p.Id">@p.FullName</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="small fw-700 text-muted d-block mb-3">NOTE</label>

                                <input type="hidden" name="rating" id="ratingValue" value="5">

                                <div class="star-rating-widget" id="starWidget">
                                    @for (int s = 1; s <= 5; s++) {
                                        <span class="star-item" data-value="@s">
                                            <i class="bi bi-star"></i>
                                        </span>
                                    }
                                </div>

                                <div class="d-flex align-items-center gap-2 mt-2">
                                    <span id="ratingDisplay" class="fw-800 fs-4 text-warning">5.0</span>
                                    <span class="text-muted small">/ 5 étoiles</span>
                                    <span id="ratingLabel"
                                        class="badge rounded-pill ms-1"
                                        style="background:#d1fae5; color:#065f46;">
                                        Excellent
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-7">
                            <label class="small fw-700 text-muted d-block mb-2">
                                VOTRE AVIS
                            </label>
                            <textarea name="comment"
                                      class="form-control form-custom"
                                      placeholder="Décrivez votre expérience : ponctualité, qualité du travail, professionnalisme..."
                                      rows="7"
                                      required
                                      minlength="10"
                                      maxlength="500"></textarea>
                            <div class="d-flex justify-content-between mt-1">
                                <small class="text-muted">Minimum 10 caractères</small>
                                <small class="text-muted" id="charCount">0 / 2000</small>
                            </div>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn-action w-100 py-3 rounded-3">
                                <i class="bi bi-send-fill me-2"></i>Publier mon avis
                            </button>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* ── Widget étoiles ── */
    .star-rating-widget {
        display: flex;
        gap: 6px;
        font-size: 2rem;
        user-select: none;
        cursor: pointer;
    }

    .star-item {
        position: relative;
        color: #e2e8f0;          /* gris par défaut */
        transition: color 0.1s ease;
        line-height: 1;
    }

    .star-item.active  { color: #f59e0b; }   /* orange sélectionné */
    .star-item.hovered { color: #fbbf24; }   /* jaune clair au survol */

    /* Demi-étoile : on swap juste l'icône en JS */
    .star-item i { pointer-events: none; }   /* le clic va au span, pas à l'icône */
</style>

<script>
(function () {
    const widget  = document.getElementById('starWidget');
    const input   = document.getElementById('ratingValue');
    const display = document.getElementById('ratingDisplay');
    const label   = document.getElementById('ratingLabel');

    if (!widget) return;

    const labels = {
        0.5: { text: 'Très mauvais', bg: '#fee2e2', color: '#991b1b' },
        1.0: { text: 'Mauvais',      bg: '#fee2e2', color: '#991b1b' },
        1.5: { text: 'Insuffisant',  bg: '#ffedd5', color: '#9a3412' },
        2.0: { text: 'Médiocre',     bg: '#ffedd5', color: '#9a3412' },
        2.5: { text: 'Passable',     bg: '#fef9c3', color: '#854d0e' },
        3.0: { text: 'Correct',      bg: '#fef9c3', color: '#854d0e' },
        3.5: { text: 'Bien',         bg: '#dcfce7', color: '#166534' },
        4.0: { text: 'Très bien',    bg: '#dcfce7', color: '#166534' },
        4.5: { text: 'Remarquable',  bg: '#d1fae5', color: '#065f46' },
        5.0: { text: 'Excellent',    bg: '#d1fae5', color: '#065f46' },
    };

    const stars = Array.from(widget.querySelectorAll('.star-item'));

    function getValueFromEvent(e) {
        const star  = e.currentTarget;
        const rect  = star.getBoundingClientRect();
        const posX  = e.clientX - rect.left;
        const isLeftHalf = posX < rect.width / 2;
        const fullValue  = parseFloat(star.dataset.value);
        return isLeftHalf ? fullValue - 0.5 : fullValue;
    }

    function setRating(value) {
        value = Math.round(value * 2) / 2;
        if (value < 0.5) value = 0.5;

        input.value = value;

        display.textContent = value.toFixed(1);

        const key  = value.toFixed(1);
        const info = labels[parseFloat(key)]
            ?? { text: '', bg: '#fef9c3', color: '#854d0e' };
        label.textContent      = info.text;
        label.style.background = info.bg;
        label.style.color      = info.color;

        renderStars(value);
    }

    function renderStars(value) {
        stars.forEach(star => {
            const sv = parseFloat(star.dataset.value);  // 1, 2, 3, 4, 5
            star.classList.remove('active', 'hovered');

            if (value >= sv) {
                star.querySelector('i').className = 'bi bi-star-fill';
                star.classList.add('active');
            } else if (value >= sv - 0.5) {
                star.querySelector('i').className = 'bi bi-star-half';
                star.classList.add('active');
            } else {
                star.querySelector('i').className = 'bi bi-star';
            }
        });
    }

    function highlightStars(value) {
        stars.forEach(star => {
            const sv = parseFloat(star.dataset.value);
            star.classList.remove('hovered');

            if (value >= sv) {
                star.querySelector('i').className = 'bi bi-star-fill';
                star.classList.add('hovered');
            } else if (value >= sv - 0.5) {
                star.querySelector('i').className = 'bi bi-star-half';
                star.classList.add('hovered');
            } else {
                star.querySelector('i').className = 'bi bi-star';
            }
        });
    }

    stars.forEach(star => {

        star.addEventListener('click', (e) => {
            const val = getValueFromEvent(e);
            setRating(val);
        });

        star.addEventListener('mousemove', (e) => {
            const val = getValueFromEvent(e);
            highlightStars(val);

            display.textContent = val.toFixed(1);
            const info = labels[val] ?? { text: '', bg: '#fef9c3', color: '#854d0e' };
            label.textContent      = info.text;
            label.style.background = info.bg;
            label.style.color      = info.color;
        });
    });

    widget.addEventListener('mouseleave', () => {
        const currentValue = parseFloat(input.value) || 5;
        renderStars(currentValue);
        display.textContent    = currentValue.toFixed(1);
        const info = labels[currentValue] ?? { text: '', bg: '#d1fae5', color: '#065f46' };
        label.textContent      = info.text;
        label.style.background = info.bg;
        label.style.color      = info.color;
    });

    setRating(5);
})();

const textarea  = document.querySelector('textarea[name="comment"]');
const charCount = document.getElementById('charCount');
if (textarea && charCount) {
    textarea.addEventListener('input', () => {
        const len = textarea.value.length;
        charCount.textContent = len + ' / 2000';
        charCount.style.color = len > 1800 ? '#ef4444' : '';
    });
}
</script>

<div class="modal fade" id="bookingModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px;">
            <div class="modal-body p-4 text-center">
                <h6 class="fw-800 mb-1" id="bookingProviderName">--</h6>
                <div id="bookingContactText" class="small text-success fw-600 mb-3"></div>
                <form asp-action="CreateBooking" method="post">
                    <input type="hidden" name="ProviderId" id="inputProviderId" />
                    <input type="text" name="ServiceName" class="form-control mb-2 form-custom" placeholder="Service (ex: Plomberie)" required />
                    <input type="number" name="TotalPrice" class="form-control mb-3 form-custom" placeholder="Budget (AR)" required />
                    <button type="submit" class="btn-action w-100 py-2">Confirmer</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function openBookingModal(id, name, phone) {
        document.getElementById('inputProviderId').value = id;
        document.getElementById('bookingProviderName').innerText = name;
        document.getElementById('bookingContactText').innerText = phone ? "Tél: " + phone : "";
        new bootstrap.Modal(document.getElementById('bookingModal')).show();
    }

    document.getElementById('ratingRange')?.addEventListener('input', function(e) {
        document.getElementById('ratingVal').innerText = e.target.value + ' / 5';
    });
</script>