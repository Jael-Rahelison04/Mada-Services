@model IEnumerable<MadaServices.Models.Review>
@{
    ViewData["Title"] = "Mon Espace Client";
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-5">
        <div>
            <h2 class="fw-800 text-dark mb-1">Salama, @User.Identity?.Name ! 👋</h2>
            <p class="text-muted">Ravi de vous revoir. Voici l'aperçu de votre activité.</p>
        </div>
        <div class="d-none d-md-block">
            <span class="badge bg-white shadow-sm text-dark border rounded-pill px-3 py-2">
                <i class="bi bi-calendar3 text-primary me-2"></i> @DateTime.Now.ToString("dd MMMM yyyy")
            </span>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-5 p-4 bg-white h-100 position-relative overflow-hidden hover-up">
                <div class="position-relative z-1">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-indigo-soft p-3 rounded-4 me-3">
                            <i class="bi bi-chat-square-heart text-indigo fs-4"></i>
                        </div>
                        <h6 class="fw-bold mb-0 text-secondary">Avis publiés</h6>
                    </div>
                    <h2 class="fw-800 mb-1">@ViewBag.TotalReviews</h2>
                    <p class="text-muted small mb-0">+12% ce mois-ci</p>
                </div>
                <div class="deco-circle-1"></div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-5 p-4 bg-white h-100 position-relative overflow-hidden hover-up">
                <div class="position-relative z-1">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success-soft p-3 rounded-4 me-3">
                            <i class="bi bi-award text-success fs-4"></i>
                        </div>
                        <h6 class="fw-bold mb-0 text-secondary">Dernier Expert</h6>
                    </div>
                    <h2 class="fw-800 text-truncate mb-1" style="max-width: 100%;">@ViewBag.LastProvider</h2>
                    <p class="text-muted small mb-0">Service complété avec succès</p>
                </div>
                <div class="deco-circle-2"></div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 rounded-5 p-4 h-100 bg-vibrant text-white shadow-vibrant hover-up">
                <h5 class="fw-bold mb-2">Trouver un pro ?</h5>
                <p class="small opacity-75 mb-4">Besoin d'un dépannage ou d'un service rapide ?</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-glass w-100 rounded-pill fw-bold py-2">
                    <i class="bi bi-search me-2"></i> Explorer les offres
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-5 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                    <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Avis récents</h5>
                    <a asp-action="MyReviews" class="btn btn-light btn-sm rounded-pill px-3 fw-bold text-indigo">Voir tout</a>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <img src="https://illustrations.popsy.co/gray/not-found.svg" alt="Aucun avis" style="width: 150px;" class="mb-3 opacity-50">
                        <p class="text-muted">Aucun avis posté pour le moment.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle custom-table">
                            <thead>
                                <tr class="text-muted small">
                                    <th class="border-0 ps-3">PRESTATAIRE</th>
                                    <th class="border-0">NOTE</th>
                                    <th class="border-0">COMMENTAIRE</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var review in Model)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm me-3 bg-light rounded-3 text-primary fw-bold">
                                                    @(review.Provider?.FullName?.Substring(0, 1) ?? "P")
                                                </div>
                                                <span class="fw-bold text-dark">@review.Provider?.FullName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="badge-rating">
                                                <i class="bi bi-star-fill me-1"></i> @review.Rating
                                            </div>
                                        </td>
                                        <td>
                                            <div class="text-muted small text-truncate-2">
                                                "@review.Comment"
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 bg-dark-modern text-white rounded-5 p-4 shadow-lg h-100">
                <h5 class="fw-bold mb-4">Besoin d'aide ?</h5>
                <div class="help-item mb-4">
                    <div class="d-flex align-items-start mb-3">
                        <div class="icon-circle bg-white-10 me-3">
                            <i class="bi bi-shield-check text-success"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Paiement Sécurisé</h6>
                            <p class="small text-white-50 mb-0">Tous vos échanges sont protégés.</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-start">
                        <div class="icon-circle bg-white-10 me-3">
                            <i class="bi bi-headset text-info"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Support Mada</h6>
                            <p class="small text-white-50 mb-0">Disponible 24/7 pour vous aider.</p>
                        </div>
                    </div>
                </div>
                <div class="mt-auto">
                    <button class="btn btn-outline-light w-100 rounded-pill btn-sm py-2">
                        <i class="bi bi-megaphone me-2"></i>Signaler un souci
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Couleurs & Backgrounds */
    :root {
        --indigo-vibrant: #6c5ce7;
        --success-vibrant: #00b894;
    }

    .bg-indigo-soft { background-color: rgba(108, 92, 231, 0.08); }
    .bg-success-soft { background-color: rgba(0, 184, 148, 0.08); }
    .bg-dark-modern { background: linear-gradient(145deg, #1e293b, #0f172a); }
    .bg-vibrant { background: linear-gradient(135deg, var(--indigo-vibrant), #a29bfe); }
    
    .text-indigo { color: var(--indigo-vibrant); }
    .fw-800 { font-weight: 800; }
    .rounded-5 { border-radius: 1.5rem !important; }

    /* Effects */
    .hover-up { transition: all 0.3s ease; }
    .hover-up:hover { transform: translateY(-8px); }
    .shadow-vibrant { box-shadow: 0 15px 35px rgba(108, 92, 231, 0.3) !important; }
    
    /* Decoration inside cards */
    .deco-circle-1, .deco-circle-2 {
        position: absolute; width: 100px; height: 100px;
        border-radius: 50%; bottom: -30px; right: -30px; opacity: 0.05;
    }
    .deco-circle-1 { background: var(--indigo-vibrant); }
    .deco-circle-2 { background: var(--success-vibrant); }

    /* Table & Rating */
    .custom-table thead th { letter-spacing: 1px; font-weight: 700; color: #94a3b8; }
    .avatar-sm { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; }
    .badge-rating {
        background: #fff8e1; color: #ff8f00;
        padding: 5px 12px; border-radius: 10px;
        font-weight: 700; font-size: 0.85rem;
        display: inline-block;
    }
    .text-truncate-2 {
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
    }

    /* Buttons & Icons */
    .btn-glass { background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255, 255, 255, 0.3); color: white; transition: 0.3s; }
    .btn-glass:hover { background: white; color: var(--indigo-vibrant); }
    .icon-circle { width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
    .bg-white-10 { background: rgba(255, 255, 255, 0.1); }
</style>