@{
    ViewData["Title"] = "Accès Refusé";
}

<div class="container py-5 text-center" style="margin-top: 100px;">
    <div class="icon-shape bg-indigo-soft mx-auto mb-4" style="width: 100px; height: 100px; border-radius: 50%;">
        <i class="bi bi-shield-lock-fill text-brand-main display-4"></i>
    </div>
    
    <h1 class="fw-800 text-brand-dark mb-3">Oups ! Accès restreint.</h1>
    <p class="text-muted mx-auto mb-5" style="max-width: 500px;">
        Désolé, cette section est réservée aux profils <strong>Clients</strong>. 
        Si vous êtes un prestataire, veuillez utiliser votre tableau de bord dédié.
    </p>

    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            Retour à l'accueil
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-vibrant px-4 rounded-pill">
                Changer de compte
            </button>
        </form>
    </div>
</div>

<style>
    .bg-indigo-soft { background-color: rgba(67, 56, 202, 0.1); display: flex; align-items: center; justify-content: center; }
</style>