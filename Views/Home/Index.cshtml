@model IEnumerable<MadaServices.Models.Provider>
@{
    ViewData["Title"] = "Explorer les Experts";
    var cities = ViewBag.Cities as List<MadaServices.Models.City> ?? new List<MadaServices.Models.City>();
    var categories = ViewBag.Categories as List<MadaServices.Models.Category> ?? new List<MadaServices.Models.Category>();
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --brand-purple: #6c5ce7;
        --brand-purple-dark: #5649c1;
        --brand-green: #00b894;
        --brand-green-light: #d1fae5;
        --slate-900: #0f172a;
        --bg-light: #f8fafc;
        --vibrant-gradient: linear-gradient(135deg, #6c5ce7 0%, #00b894 100%);
        --vibrant-gradient-hover: linear-gradient(135deg, #5649c1 0%, #00a383 100%);
    }

    body { font-family: 'Outfit', sans-serif; background-color: var(--bg-light); color: var(--slate-900); overflow-x: hidden; }

    /* --- Animations --- */
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.6s cubic-bezier(0.5, 0, 0, 1);
    }
    .reveal.active {
        opacity: 1;
        transform: translateY(0);
    }

    /* --- Hero Section --- */
    .hero-explore {
        background: var(--vibrant-gradient);
        padding: 120px 0 160px;
        color: white;
        border-radius: 0 0 80px 80px;
        position: relative;
        overflow: hidden;
    }

    .hero-explore::after {
        content: "";
        position: absolute;
        top: -50%; left: -50%;
        width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 60%);
        animation: rotateLight 20s linear infinite;
        pointer-events: none;
    }

    @@keyframes rotateLight {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .hero-title { font-size: 3.5rem; font-weight: 800; letter-spacing: -1.5px; line-height: 1.1; }

    /* --- Search Bar --- */
    .search-wrapper { margin-top: -80px; position: relative; z-index: 100; padding: 0 20px; }
    
    .glass-search-bar {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border-radius: 40px;
        padding: 15px;
        border: 1px solid white;
        box-shadow: 0 25px 50px -12px rgba(108, 92, 231, 0.15);
    }

    .input-group-text i { font-size: 1.2rem; background: var(--vibrant-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* --- Pills --- */
    .category-pills { display: flex; gap: 12px; overflow-x: auto; padding: 20px 0; scrollbar-width: none; }
    .category-pills::-webkit-scrollbar { display: none; }
    @@media (min-width: 992px) { .category-pills { justify-content: center; } }

    .pill-item {
        padding: 10px 26px; background: white; border: 1px solid #e2e8f0; border-radius: 50px;
        white-space: nowrap; cursor: pointer; font-weight: 600; font-size: 0.95rem;
        transition: all 0.4s ease; color: #64748b;
    }
    .pill-item.active {
        background: var(--vibrant-gradient); color: white; border-color: transparent;
        box-shadow: 0 10px 20px -3px rgba(108, 92, 231, 0.3);
    }

    /* --- Talent Cards --- */
    .talent-card {
        background: white; border-radius: 35px; padding: 30px; height: 100%;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #f1f5f9; text-align: center; position: relative; overflow: hidden;
    }
    .talent-card:hover { transform: translateY(-12px); box-shadow: 0 30px 60px -12px rgba(108, 92, 231, 0.15); border-color: rgba(108, 92, 231, 0.2); }

    .avatar-wrapper { position: relative; width: 100px; height: 100px; margin: 0 auto 20px; }
    .talent-avatar { width: 100%; height: 100%; border-radius: 30px; object-fit: cover; border: 4px solid white; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    .talent-placeholder { width: 100%; height: 100%; border-radius: 30px; background: var(--vibrant-gradient); color: white; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; font-weight: 800; }

    .status-dot { width: 16px; height: 16px; border-radius: 50%; border: 3px solid white; position: absolute; bottom: 5px; right: 5px; }
    .status-online { background: var(--brand-green); }
    .status-offline { background: #94a3b8; }

    .price-tag { background: var(--brand-green-light); color: #065f46; padding: 6px 16px; border-radius: 12px; font-weight: 800; font-size: 0.85rem; }

    .btn-profile-vibrant {
        background: var(--vibrant-gradient); color: white; border: none;
        border-radius: 15px; width: 100%; padding: 12px; font-weight: 700;
        margin-top: 20px; transition: 0.3s; text-decoration: none; display: block;
    }
    .btn-profile-vibrant:hover { background: var(--vibrant-gradient-hover); color: white; transform: translateY(-2px); }

    .filtered-out { display: none !important; }
</style>

<section class="hero-explore text-center">
    <div class="container reveal active">
        <h1 class="hero-title mb-3">Le <span style="color: #a7f3d0">Talent</span> qu'il vous faut.</h1>
        <p class="fs-5 opacity-75">La plateforme de confiance pour vos services à Madagascar.</p>
    </div>
</section>

<div class="container search-wrapper reveal active">
    <div class="glass-search-bar">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text border-0 bg-transparent"><i class="bi bi-search"></i></span>
                    <input type="text" id="liveSearch" class="form-control border-0 bg-transparent shadow-none" placeholder="Rechercher un service...">
                </div>
            </div>
            <div class="col-md-4">
                <div class="input-group border-start">
                    <span class="input-group-text border-0 bg-transparent"><i class="bi bi-geo-alt"></i></span>
                    <select id="cityFilter" class="form-select border-0 bg-transparent shadow-none">
                        <option value="all">Tout Madagascar</option>
                        @foreach (var city in cities) {
                            <option value="@city.Name">@city.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-2">
                <button id="resetFilters" class="btn btn-outline-secondary w-100 rounded-pill">Effacer</button>
            </div>
        </div>
    </div>

    <div class="category-pills mt-3">
        <div class="pill-item active" data-category="all">Tous les services</div>
        @foreach(var cat in categories) {
            <div class="pill-item" data-category="@cat.Id">@cat.Name</div>
        }
    </div>
</div>

<main class="container py-5">
    <div class="mb-4 reveal">
        <h5 class="fw-800 text-muted"><span id="resultCount">@Model.Count()</span> experts disponibles</h5>
    </div>

    <div class="row g-4" id="expertGrid">
        @{ int delayCount = 0; }
        @foreach (var pro in Model)
        {
            string d = (0.1 * (delayCount % 4))
                .ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) + "s";

            <div class="col-xl-3 col-lg-4 col-sm-6 pro-item reveal"
                data-cat-id="@pro.CategoryId"
                data-city-name="@pro.City"
                data-search-blob="@(pro.FullName?.ToLower() ?? "") @(pro.JobTitle?.ToLower() ?? "") @(pro.City?.ToLower() ?? "")"
                style="transition-delay: @d">

                @await Html.PartialAsync("_ProviderCard", pro)

            </div>
            delayCount++;
        }
    </div>

    <div id="noResults" class="text-center py-5 d-none">
        <h3 class="fw-800">Aucun expert trouvé</h3>
        <button id="resetEmpty" class="btn btn-purple rounded-pill px-4 mt-3">Réinitialiser</button>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const items = Array.from(document.querySelectorAll('.pro-item'));
        const searchInput = document.getElementById('liveSearch');
        const cityFilter = document.getElementById('cityFilter');
        const catTags = document.querySelectorAll('.pill-item');
        const resultCount = document.getElementById('resultCount');

        const updateDisplay = () => {
            let count = 0;
            const query = searchInput.value.toLowerCase();
            const city = cityFilter.value;
            const cat = document.querySelector('.pill-item.active').dataset.category;

            items.forEach(item => {
                const matchesSearch = item.dataset.searchBlob.includes(query);
                const matchesCity = city === "all" || item.dataset.cityName === city;
                const matchesCat = cat === "all" || item.dataset.catId === cat;

                if (matchesSearch && matchesCity && matchesCat) {
                    item.classList.remove('filtered-out');
                    count++;
                } else {
                    item.classList.add('filtered-out');
                }
            });
            resultCount.textContent = count;
            document.getElementById('noResults').classList.toggle('d-none', count > 0);
        };

        searchInput.addEventListener('input', updateDisplay);
        cityFilter.addEventListener('change', updateDisplay);
        catTags.forEach(tag => tag.addEventListener('click', function() {
            catTags.forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            updateDisplay();
        }));

        // Réinitialisation des filtres
        document.getElementById('resetFilters').addEventListener('click', () => {
            document.getElementById('liveSearch').value = '';
            document.getElementById('cityFilter').value = 'all';
            document.querySelectorAll('.pill-item').forEach(p => p.classList.remove('active'));
            document.querySelector('.pill-item[data-category="all"]').classList.add('active');
            updateDisplay();
        });

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    });
</script>